---
// CTA.astro – final call-to-action banner
---

<section
  id="get-started"
  class="py-24 lg:py-32 relative overflow-hidden"
  aria-labelledby="cta-heading"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative glass rounded-3xl p-12 lg:p-20 text-center overflow-hidden">

      <!-- Background accent -->
      <div class="absolute inset-0 -z-10" aria-hidden="true">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-brand-600/30 blur-[80px] rounded-full"></div>
      </div>

      <p class="text-brand-400 text-sm font-semibold uppercase tracking-widest mb-4">Get Started</p>
      <h2 id="cta-heading" class="text-4xl sm:text-5xl lg:text-6xl font-display font-800 text-white mb-6">
        Ready to get started?<br />
        <span class="text-gradient">Try it free today.</span>
      </h2>
      <p class="max-w-xl mx-auto text-slate-400 text-lg leading-relaxed mb-10">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          id="cta-primary-btn"
          href="#"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-semibold rounded-xl bg-brand-500 hover:bg-brand-400 text-white transition-all duration-200 hover:shadow-2xl hover:shadow-brand-500/30 hover:-translate-y-1 glow"
        >
          Start free — no credit card
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a
          id="cta-secondary-btn"
          href="https://wa.me/916382729213"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 text-base font-semibold rounded-xl glass text-white hover:bg-white/10 transition-all duration-200 hover:-translate-y-1"
        >
          Talk to us
        </a>
      </div>

      <p class="mt-6 text-slate-500 text-sm">
        14-day free trial · No credit card · Cancel anytime
      </p>
    </div>
  </div>
</section>
