---
// HowItWorks.astro – numbered steps section
const steps = [
  {
    number: '01',
    title: 'Lorem ipsum dolor',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua ut enim.',
  },
  {
    number: '02',
    title: 'Consectetur adipiscing',
    description: 'Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor.',
  },
  {
    number: '03',
    title: 'Sed do eiusmod tempor',
    description: 'Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat.',
  },
];
---

<section
  id="how-it-works"
  class="py-24 lg:py-32 relative"
  aria-labelledby="how-it-works-heading"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: text -->
      <div>
        <p class="text-brand-400 text-sm font-semibold uppercase tracking-widest mb-3">How It Works</p>
        <h2 id="how-it-works-heading" class="text-4xl sm:text-5xl font-display font-700 text-white mb-6">
          Three steps to<br />
          <span class="text-gradient">get started</span>
        </h2>
        <p class="text-slate-400 text-lg leading-relaxed mb-10">
          Lorem ipsum dolor sit amet consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
        </p>

        <ol class="space-y-8" aria-label="Steps to get started">
          {steps.map((step) => (
            <li class="flex gap-5 group">
              <!-- Number badge -->
              <div class="flex-shrink-0 w-12 h-12 rounded-xl glass flex items-center justify-center text-brand-400 font-display font-700 text-sm group-hover:bg-brand-500/20 transition-colors duration-300">
                {step.number}
              </div>
              <div>
                <h3 class="text-white font-display font-600 text-lg mb-1">{step.title}</h3>
                <p class="text-slate-400 text-sm leading-relaxed">{step.description}</p>
              </div>
            </li>
          ))}
        </ol>

        <a
          id="how-it-works-cta"
          href="#get-started"
          class="inline-flex items-center gap-2 mt-10 px-6 py-3 text-sm font-semibold rounded-lg bg-brand-500 hover:bg-brand-400 text-white transition-all duration-200 hover:shadow-lg hover:shadow-brand-500/25 hover:-translate-y-0.5"
        >
          Start now — it's free
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Right: visual placeholder -->
      <div class="relative hidden lg:block">
        <div class="glass rounded-2xl p-8 min-h-80 flex items-center justify-center text-slate-600">
          <div class="text-center">
            <div class="w-20 h-20 mx-auto mb-4 rounded-2xl bg-white/5 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <p class="text-sm font-medium">Illustration / animation goes here</p>
          </div>
        </div>
        <!-- decorative dots -->
        <div class="absolute -top-4 -right-4 w-24 h-24 opacity-20" aria-hidden="true"
          style="background-image: radial-gradient(circle, rgba(99,102,241,0.8) 1px, transparent 1px); background-size: 8px 8px;">
        </div>
        <div class="absolute -bottom-4 -left-4 w-24 h-24 opacity-20" aria-hidden="true"
          style="background-image: radial-gradient(circle, rgba(14,144,226,0.8) 1px, transparent 1px); background-size: 8px 8px;">
        </div>
      </div>

    </div>
  </div>
</section>
