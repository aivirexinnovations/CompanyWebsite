---
// Pricing.astro – three-tier pricing section
const plans = [
  {
    name: 'Starter',
    price: '$0',
    period: '/month',
    description: 'Perfect for individuals and small projects getting started.',
    features: [
      'Lorem ipsum dolor sit amet',
      'Consectetur adipiscing elit',
      'Sed do eiusmod tempor',
      'Up to 3 projects',
      'Community support',
    ],
    cta: { label: 'Get started free', href: '#get-started', id: 'pricing-starter-cta' },
    highlighted: false,
  },
  {
    name: 'Pro',
    price: '$49',
    period: '/month',
    description: 'For growing teams that need more power and flexibility.',
    features: [
      'Everything in Starter',
      'Ut enim ad minim veniam',
      'Quis nostrud exercitation',
      'Unlimited projects',
      'Priority email support',
      'Advanced analytics',
    ],
    cta: { label: 'Start free trial', href: '#get-started', id: 'pricing-pro-cta' },
    highlighted: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    description: 'Dedicated infrastructure and support for large organizations.',
    features: [
      'Everything in Pro',
      'Duis aute irure dolor',
      'Reprehenderit in voluptate',
      'Custom integrations',
      'Dedicated account manager',
      'SLA & uptime guarantee',
    ],
    cta: { label: 'Contact sales', href: '#contact', id: 'pricing-enterprise-cta' },
    highlighted: false,
  },
];
---

<section
  id="pricing"
  class="py-24 lg:py-32 relative"
  aria-labelledby="pricing-heading"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-16">
      <p class="text-brand-400 text-sm font-semibold uppercase tracking-widest mb-3">Pricing</p>
      <h2 id="pricing-heading" class="text-4xl sm:text-5xl font-display font-700 text-white mb-4">
        Simple, transparent<br />
        <span class="text-gradient">pricing</span>
      </h2>
      <p class="max-w-xl mx-auto text-slate-400 text-lg leading-relaxed">
        No hidden fees. No surprise charges. Cancel anytime.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 lg:gap-8 items-center">
      {plans.map((plan) => (
        <article
          class:list={[
            'relative rounded-2xl p-7 flex flex-col gap-6 transition-all duration-300 hover:-translate-y-1',
            plan.highlighted
              ? 'bg-brand-600/20 border border-brand-500/40 shadow-2xl shadow-brand-500/10 glow scale-105'
              : 'glass hover:bg-white/[0.06]',
          ]}
        >
          {plan.highlighted && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-brand-500 text-white text-xs font-semibold">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              Most Popular
            </div>
          )}

          <div>
            <h3 class="text-white font-display font-600 text-xl mb-1">{plan.name}</h3>
            <p class="text-slate-400 text-sm">{plan.description}</p>
          </div>

          <div class="flex items-end gap-1">
            <span class="text-white font-display font-800 text-5xl">{plan.price}</span>
            {plan.period && <span class="text-slate-400 text-sm mb-2">{plan.period}</span>}
          </div>

          <ul class="space-y-3 flex-1" aria-label={`${plan.name} plan features`}>
            {plan.features.map((f) => (
              <li class="flex items-start gap-2.5 text-sm text-slate-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-400 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {f}
              </li>
            ))}
          </ul>

          <a
            id={plan.cta.id}
            href={plan.cta.href}
            class:list={[
              'inline-flex justify-center items-center gap-2 w-full py-3 rounded-lg text-sm font-semibold transition-all duration-200',
              plan.highlighted
                ? 'bg-brand-500 hover:bg-brand-400 text-white hover:shadow-lg hover:shadow-brand-500/30'
                : 'glass text-white hover:bg-white/10',
            ]}
          >
            {plan.cta.label}
          </a>
        </article>
      ))}
    </div>

    <p class="text-center text-slate-500 text-sm mt-10">
      All plans include a 14-day free trial. No credit card required.
    </p>

  </div>
</section>
