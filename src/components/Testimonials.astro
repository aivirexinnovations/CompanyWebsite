---
// Testimonials.astro – social proof section
const testimonials = [
  {
    quote: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam.',
    name: 'Jane Doe',
    role: 'CEO at Acme Corp',
    avatar: 'JD',
    avatarColor: 'from-pink-400 to-rose-500',
  },
  {
    quote: 'Quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate.',
    name: 'John Smith',
    role: 'CTO at TechCo',
    avatar: 'JS',
    avatarColor: 'from-violet-400 to-purple-500',
  },
  {
    quote: 'Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum sed perspiciatis.',
    name: 'Alex Kim',
    role: 'Founder at StartupXYZ',
    avatar: 'AK',
    avatarColor: 'from-sky-400 to-blue-500',
  },
];

const stats = [
  { value: '10M+',  label: 'Lorem processed' },
  { value: '99.9%', label: 'Uptime SLA' },
  { value: '150+',  label: 'Countries' },
  { value: '4.9★',  label: 'Avg. rating' },
];
---

<section
  id="testimonials"
  class="py-24 lg:py-32 relative overflow-hidden"
  aria-labelledby="testimonials-heading"
>
  <!-- Top border -->
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Stats bar -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 mb-20">
      {stats.map((stat) => (
        <div class="text-center glass rounded-2xl py-6">
          <div class="text-3xl sm:text-4xl font-display font-800 text-gradient">{stat.value}</div>
          <div class="text-slate-400 text-sm mt-1">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- Section header -->
    <div class="text-center mb-12">
      <p class="text-brand-400 text-sm font-semibold uppercase tracking-widest mb-3">Testimonials</p>
      <h2 id="testimonials-heading" class="text-4xl sm:text-5xl font-display font-700 text-white mb-4">
        Loved by teams<br />
        <span class="text-gradient">worldwide</span>
      </h2>
    </div>

    <!-- Testimonials grid -->
    <div class="grid md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <figure class="glass rounded-2xl p-6 flex flex-col gap-4 hover:bg-white/[0.06] transition-all duration-300 hover:-translate-y-1">
          <!-- Stars -->
          <div class="flex gap-1" aria-label="5 out of 5 stars">
            {Array(5).fill(0).map(() => (
              <svg class="w-4 h-4 text-amber-400 fill-current" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>

          <blockquote class="text-slate-300 text-sm leading-relaxed flex-1">
            "{t.quote}"
          </blockquote>

          <figcaption class="flex items-center gap-3">
            <div class={`w-10 h-10 rounded-full bg-gradient-to-br ${t.avatarColor} flex items-center justify-center text-white font-bold text-sm flex-shrink-0`} aria-hidden="true">
              {t.avatar}
            </div>
            <div>
              <div class="text-white font-semibold text-sm">{t.name}</div>
              <div class="text-slate-500 text-xs">{t.role}</div>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>

  </div>
</section>
