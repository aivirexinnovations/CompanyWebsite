---
/**
 * FAQList.astro
 * Self-contained FAQ accordion — renders the list AND wires up the JS.
 * Uses an id namespace so multiple lists can live on the same page.
 *
 * Props
 * ─────
 * items : { q: string; a: string }[]  — FAQ data
 * id    : string?  — unique root id  (default 'faq-list')
 */
interface FAQItem {
  q: string;
  a: string;
}

interface Props {
  items: FAQItem[];
  id?:   string;
}

const { items, id = 'faq-list' } = Astro.props;
---

<div class="space-y-2.5" id={id} data-faq-list>
  {items.map((item, i) => {
    const btnId    = `${id}-btn-${i}`;
    const answerId = `${id}-ans-${i}`;
    return (
      <div class={`glass rounded-xl overflow-hidden stagger-${(i % 5) + 1}`} data-reveal="blur" data-faq-item>
        <button
          type="button"
          id={btnId}
          aria-expanded="false"
          aria-controls={answerId}
          class="w-full flex items-center justify-between gap-4 px-5 sm:px-6 py-4 text-left text-white font-semibold text-sm hover:bg-white/5 transition-colors duration-200"
          data-faq-trigger
        >
          <span>{item.q}</span>
          <!-- Chevron rotates 180° when open -->
          <svg
            class="w-5 h-5 text-slate-500 flex-shrink-0 transition-transform duration-300"
            fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
            aria-hidden="true"
            data-faq-chevron
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>

        <div
          id={answerId}
          role="region"
          aria-labelledby={btnId}
          style="max-height: 0; overflow: hidden; transition: max-height 0.32s ease;"
          data-faq-answer
        >
          <p class="px-5 sm:px-6 pb-5 pt-1 text-slate-400 text-sm leading-relaxed">{item.a}</p>
        </div>
      </div>
    );
  })}
</div>

<script>
  // Initialize all FAQ lists on the page
  document.querySelectorAll('[data-faq-list]').forEach((list) => {
    list.querySelectorAll('[data-faq-trigger]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const isOpen   = btn.getAttribute('aria-expanded') === 'true';
        const answer   = document.getElementById(btn.getAttribute('aria-controls') || '');
        const chevron  = btn.querySelector('[data-faq-chevron]');

        // Close all siblings first
        list.querySelectorAll('[data-faq-trigger]').forEach((b) => {
          b.setAttribute('aria-expanded', 'false');
          const a = document.getElementById(b.getAttribute('aria-controls') || '');
          if (a) a.style.maxHeight = '0';
          const c = b.querySelector('[data-faq-chevron]');
          if (c) c.style.transform = '';
        });

        // Toggle clicked item
        if (!isOpen && answer) {
          btn.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = answer.scrollHeight + 'px';
          if (chevron) chevron.style.transform = 'rotate(180deg)';
        }
      });
    });
  });
</script>
