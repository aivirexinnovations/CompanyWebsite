---
/**
 * FeatureRow.astro
 * Alternating two-column content row (text + visual) used in
 * the Attendify features section.
 *
 * Props
 * ─────
 * title : string
 * body  : string
 * flip  : boolean  — puts visual on the left (default false)
 *
 * Slots
 * ─────
 * visual  — custom visual / image / lottie (optional, falls back to placeholder)
 * extra   — optional extra content below the body text (CTAs, chips, etc.)
 */
interface Props {
  title: string;
  body:  string;
  flip?: boolean;
}

const { title, body, flip = false } = Astro.props;
---

<div
  class:list={[
    'grid lg:grid-cols-2 gap-10 lg:gap-16 items-center',
    flip ? 'lg:grid-flow-dense' : '',
  ]}
>
  <!-- Text column -->
  <div class:list={[flip ? 'lg:col-start-2' : '']}>
    <h3 class="text-2xl sm:text-3xl font-display font-700 text-white mb-4 leading-snug">
      {title}
    </h3>
    <p class="text-slate-400 leading-relaxed text-sm sm:text-base">{body}</p>
    <slot name="extra" />
  </div>

  <!-- Visual column -->
  <div class:list={[flip ? 'lg:col-start-1 lg:row-start-1' : '', 'flex justify-center']}>
    <slot name="visual">
      <!-- Default placeholder -->
      <div class="glass rounded-2xl w-full max-w-sm h-56 flex flex-col items-center justify-center gap-2 text-slate-600">
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="12" cy="11" r="3"/><path d="M3 19c1.4-2.4 4-4 9-4s7.6 1.6 9 4"/>
        </svg>
        <span class="text-xs font-medium">Feature illustration</span>
      </div>
    </slot>
  </div>
</div>
