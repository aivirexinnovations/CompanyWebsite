---
// HeroClarityCanvas.astro
---

<!-- Aurora fallback (shows if WebGL no-ops / reduced-motion) -->
<div class="clarity-aura absolute inset-0" aria-hidden="true"></div>
<!-- Live WebGL aurora -->
<canvas data-clarity-aurora class="absolute inset-0 w-full h-full pointer-events-none opacity-90" aria-hidden="true"></canvas>
<!-- Flow-field currents + hidden customers + lens -->
<canvas data-clarity-field class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true"></canvas>

<style>
  .clarity-aura {
    background:
      radial-gradient(60% 80% at 18% 30%, rgba(33,165,237,0.32), transparent 60%),
      radial-gradient(55% 65% at 72% 62%, rgba(56,140,255,0.22), transparent 60%),
      radial-gradient(60% 70% at 88% 18%, rgba(95,199,255,0.20), transparent 60%),
      #03060f;
  }
</style>

<script>
  (() => {
    const hero = document.getElementById('hero');
    const fieldC = hero && hero.querySelector('[data-clarity-field]');
    if (!hero || !fieldC) return;
    
    const visFlag = (el) => {
      const s = { v: true };
      new IntersectionObserver((es) => es.forEach((e) => (s.v = e.isIntersecting)), { threshold: 0.02 }).observe(el);
      return s;
    };
    const makeNoise = () => {
      const p = new Uint8Array(512);
      const perm = Array.from({ length: 256 }, (_, i) => i);
      for (let i = 255; i > 0; i--) { const j = (Math.random() * (i + 1)) | 0; [perm[i], perm[j]] = [perm[j], perm[i]]; }
      for (let i = 0; i < 512; i++) p[i] = perm[i & 255];
      const fade = (t) => t * t * t * (t * (t * 6 - 15) + 10);
      const lerp = (a, b, t) => a + (b - a) * t;
      const grad = (h, x, y) => { const u = (h & 1) ? x : -x, v = (h & 2) ? y : -y; return u + v; };
      return (x, y) => {
        const X = Math.floor(x) & 255, Y = Math.floor(y) & 255;
        x -= Math.floor(x); y -= Math.floor(y);
        const u = fade(x), v = fade(y);
        const a = p[X] + Y, b = p[X + 1] + Y;
        return lerp(lerp(grad(p[a], x, y), grad(p[b], x - 1, y), u), lerp(grad(p[a + 1], x, y - 1), grad(p[b + 1], x - 1, y - 1), u), v);
      };
    };

    // — calm aurora backdrop (WebGL) —
    const auroraC = hero.querySelector('[data-clarity-aurora]');
    if (auroraC) {
      const gl = auroraC.getContext('webgl', { antialias: false, alpha: true });
      if (gl) {
        const vs = `attribute vec2 p;void main(){gl_Position=vec4(p,0.,1.);}`;
        const fs = `precision highp float;uniform vec2 u_res;uniform float u_time;
          float hash(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453);}
          float noise(vec2 p){vec2 i=floor(p),f=fract(p);vec2 u=f*f*(3.-2.*f);
            return mix(mix(hash(i),hash(i+vec2(1,0)),u.x),mix(hash(i+vec2(0,1)),hash(i+vec2(1,1)),u.x),u.y);}
          float fbm(vec2 p){float v=0.,a=.55;mat2 m=mat2(1.6,1.2,-1.2,1.6);
            for(int i=0;i<4;i++){v+=a*noise(p);p=m*p;a*=.5;}return v;}
          void main(){vec2 uv=gl_FragCoord.xy/u_res.xy;vec2 p=uv*vec2(1.7,1.)*2.4;
            float t=u_time*0.04;float q=fbm(p+vec2(t,t*.6));
            float n=fbm(p+2.0*vec2(q)+vec2(-t*.7,t*.4));
            vec3 cB=vec3(0.05,0.32,0.78),cT=vec3(0.11,0.52,0.94),cV=vec3(0.22,0.64,1.00);
            vec3 col=mix(cB,cT,smoothstep(0.2,0.8,n));
            col=mix(col,cV,smoothstep(0.55,1.05,fbm(p*0.7-t)));
            col*=0.30+0.7*n;
            vec3 bg=vec3(0.012,0.025,0.07);
            col=mix(bg,col,0.85);
            gl_FragColor=vec4(col,1.0);}`;
        const sh = (ty, s) => { const o = gl.createShader(ty); gl.shaderSource(o, s); gl.compileShader(o); return o; };
        const prog = gl.createProgram();
        gl.attachShader(prog, sh(gl.VERTEX_SHADER, vs));
        gl.attachShader(prog, sh(gl.FRAGMENT_SHADER, fs));
        gl.linkProgram(prog); gl.useProgram(prog);
        const buf = gl.createBuffer(); gl.bindBuffer(gl.ARRAY_BUFFER, buf);
        gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]), gl.STATIC_DRAW);
        const loc = gl.getAttribLocation(prog, 'p');
        gl.enableVertexAttribArray(loc); gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);
        const uRes = gl.getUniformLocation(prog, 'u_res'), uTime = gl.getUniformLocation(prog, 'u_time');
        const dprA = Math.min(window.devicePixelRatio || 1, 1.25);
        const rs = () => { auroraC.width = Math.floor(hero.clientWidth * dprA); auroraC.height = Math.floor(hero.clientHeight * dprA); gl.viewport(0, 0, auroraC.width, auroraC.height); };
        rs(); window.addEventListener('resize', rs);
        const visA = visFlag(hero); const t0 = performance.now();
        const la = (now) => { if (visA.v) { gl.uniform2f(uRes, auroraC.width, auroraC.height); gl.uniform1f(uTime, (now - t0) / 1000); gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4); } requestAnimationFrame(la); };
        requestAnimationFrame(la);
      }
    }

    // — field: chaotic currents that clarify + hidden customers found under the lens —
    const ctx = fieldC.getContext('2d');
    const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
    const noise = makeNoise();
    let W = 0, H = 0, R = 200;
    const clarity = ['#21a5ed', '#4cc4ff', '#5fc7ff', '#2f80ed'];
    let parts = [];
    const COUNT = window.innerWidth < 640 ? 260 : 560;
    const spawn = () => { const x = Math.random() * W, y = Math.random() * H; return { x, y, px: x, py: y, life: 0, max: 50 + Math.random() * 120, c: clarity[(Math.random() * clarity.length) | 0] }; };

    const labels = ['new lead', 'client', 'your buyer', '+ revenue', 'a fan', 'referral', 'warm lead', '+1 signup', 'customer', 'advocate'];
    let nodes = [];

    const resize = () => {
      W = hero.clientWidth; H = hero.clientHeight;
      fieldC.width = W * dpr; fieldC.height = H * dpr; ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      R = Math.max(150, Math.min(W, H) * 0.22);
      parts = Array.from({ length: COUNT }, spawn);
      const n = Math.max(6, Math.round(W / 220));
      nodes = Array.from({ length: n }, () => ({ x: W * (0.34 + Math.random() * 0.6), y: H * (0.12 + Math.random() * 0.76), label: labels[(Math.random() * labels.length) | 0], phase: Math.random() * 6.28, found: 0 }));
    };
    resize(); window.addEventListener('resize', resize);

    let tx = W * 0.62, ty = H * 0.5, mx = tx, my = ty, active = false;
    hero.addEventListener('pointermove', (e) => { const r = hero.getBoundingClientRect(); tx = e.clientX - r.left; ty = e.clientY - r.top; active = true; });
    hero.addEventListener('pointerleave', () => { active = false; });
    const hint = hero.querySelector('[data-clarity-hint]');
    hero.addEventListener('pointermove', () => { if (hint) { hint.style.transition = 'opacity .6s'; hint.style.opacity = '0'; } }, { once: true });

    const vis = visFlag(hero);
    const scale = 0.0016, zStep = 0.0007, speed = 1.35; let z = 0;
    const loop = () => {
      if (vis.v) {
        if (!active) { tx = W * (0.6 + Math.sin(performance.now() * 0.0002) * 0.12); ty = H * (0.5 + Math.cos(performance.now() * 0.00017) * 0.18); }
        mx += (tx - mx) * 0.09; my += (ty - my) * 0.09;
        z += zStep;
        ctx.clearRect(0, 0, W, H);
        ctx.lineCap = 'round';

        for (const p of parts) {
          const dx = mx - p.x, dy = my - p.y, d = Math.hypot(dx, dy);
          let a = noise(p.x * scale, p.y * scale + z) * Math.PI * 2.6;
          let prox = 0;
          if (d < R) { prox = 1 - d / R; const toC = Math.atan2(dy, dx); a = a * (1 - prox) + (toC + 0.55) * prox; }
          p.px = p.x; p.py = p.y;
          const sp = speed * (1 + prox * 0.8);
          p.x += Math.cos(a) * sp; p.y += Math.sin(a) * sp; p.life++;
          if (p.life > p.max || p.x < 0 || p.x > W || p.y < 0 || p.y > H || (prox > 0.6 && d < 14)) { Object.assign(p, spawn()); continue; }
          const lifeFade = Math.sin((p.life / p.max) * Math.PI);
          ctx.beginPath(); ctx.moveTo(p.px, p.py); ctx.lineTo(p.x, p.y);
          if (prox > 0.04) { ctx.strokeStyle = p.c; ctx.globalAlpha = (0.18 + prox * 0.6) * lifeFade; ctx.lineWidth = 0.8 + prox * 1.4; }
          else { ctx.strokeStyle = '#7e90ab'; ctx.globalAlpha = 0.10 * lifeFade; ctx.lineWidth = 0.7; }
          ctx.stroke();
        }
        ctx.globalAlpha = 1; ctx.lineWidth = 1;

        for (const nd of nodes) {
          const d = Math.hypot(nd.x - mx, nd.y - my);
          const target = d < R ? 1 - d / R : 0;
          nd.found += (target - nd.found) * 0.12;
          const pulse = 0.6 + 0.4 * Math.sin(performance.now() * 0.004 + nd.phase);
          ctx.globalAlpha = 0.05 + nd.found * 0.9 * pulse;
          ctx.strokeStyle = '#bfe6ff'; ctx.lineWidth = 1.2;
          ctx.beginPath(); ctx.arc(nd.x, nd.y, 7 + nd.found * 4, 0, 6.2832); ctx.stroke();
          ctx.globalAlpha = 0.04 + nd.found * 0.7;
          ctx.fillStyle = '#5fc7ff'; ctx.beginPath(); ctx.arc(nd.x, nd.y, 2.2, 0, 6.2832); ctx.fill();
          if (nd.found > 0.15) {
            ctx.globalAlpha = nd.found * 0.5; ctx.strokeStyle = 'rgba(95,199,255,0.6)'; ctx.lineWidth = 0.8;
            ctx.beginPath(); ctx.moveTo(nd.x, nd.y); ctx.lineTo(mx, my); ctx.stroke();
            ctx.globalAlpha = nd.found; ctx.fillStyle = '#dff1ff'; ctx.font = '600 12px "JetBrains Mono", ui-monospace, monospace'; ctx.textAlign = 'left';
            ctx.fillText(nd.label, nd.x + 12, nd.y - 9);
          }
        }
        ctx.globalAlpha = 1;

        const rg = ctx.createRadialGradient(mx, my, R * 0.2, mx, my, R);
        rg.addColorStop(0, 'rgba(33,165,237,0.05)'); rg.addColorStop(0.7, 'rgba(33,165,237,0.02)'); rg.addColorStop(1, 'rgba(33,165,237,0)');
        ctx.fillStyle = rg; ctx.beginPath(); ctx.arc(mx, my, R, 0, 6.2832); ctx.fill();
        ctx.lineWidth = 1.4; ctx.strokeStyle = 'rgba(190,230,255,0.35)';
        ctx.beginPath(); ctx.arc(mx, my, R, 0, 6.2832); ctx.stroke();
        ctx.globalAlpha = 0.5; ctx.lineWidth = 1;
        ctx.strokeStyle = '#ff5f8f'; ctx.beginPath(); ctx.arc(mx - 2.5, my, R, 0, 6.2832); ctx.stroke();
        ctx.strokeStyle = '#5f8fff'; ctx.beginPath(); ctx.arc(mx + 2.5, my, R, 0, 6.2832); ctx.stroke();
        ctx.globalAlpha = 1;
      }
      requestAnimationFrame(loop);
    };
    requestAnimationFrame(loop);
  })();
</script>
