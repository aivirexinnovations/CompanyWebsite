---
/**
 * ProjectCard.astro
 * Portfolio/work card with thumbnail area, tag badge, title, and description.
 *
 * Props
 * ─────
 * title : string
 * tag   : string  — category label (e.g. 'Web App')
 * desc  : string  — short description
 * href  : string? — link to project detail (default '#')
 */
interface Props {
  title: string;
  tag:   string;
  desc:  string;
  image?: string;
  href?: string;
}

const { title, tag, desc, image, href = '#' } = Astro.props;
---

<article class="bg-surface-800/20 border border-brand-500/10 hover:border-brand-500/30 transition-colors duration-300 rounded-lg overflow-hidden group flex flex-col">

  <!-- Thumbnail placeholder or image -->
  <div
    class="bg-surface-800/70 h-48 flex items-center justify-center border-b border-white/5 overflow-hidden"
    aria-hidden="true"
  >
    {image ? (
      <img src={image} alt="" class="w-full h-full object-cover" loading="lazy" />
    ) : (
      <svg
        class="w-10 h-10 text-surface-600"
        fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"
        aria-hidden="true"
      >
        <rect x="3" y="3" width="18" height="18" rx="2"/>
        <path d="M3 9h18M9 21V9"/>
      </svg>
    )}
  </div>

  <!-- Body -->
  <div class="p-6 flex flex-col flex-1">

    <!-- Tag -->
    <div class="mb-3">
      <span class="px-2.5 py-1 rounded-full text-xs font-semibold text-brand-300 bg-brand-500/12 border border-brand-500/20">
        {tag}
      </span>
    </div>

    <h3 class="text-white font-display font-600 text-base mb-2 group-hover:text-brand-300 transition-colors duration-200 leading-snug">
      {title}
    </h3>
    <p class="text-slate-400 text-sm leading-relaxed flex-1">{desc}</p>

    <!-- Link -->
    {href !== '#' && (
      <a
        href={href}
        class="inline-flex items-center gap-1.5 text-brand-400 hover:text-brand-300 text-xs font-semibold mt-4 transition-colors duration-200"
        aria-label={`View project: ${title}`}
      >
        View project
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    )}
  </div>
</article>
