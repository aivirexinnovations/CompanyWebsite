---
/**
 * Stat.astro
 * Single statistic cell — used inside the hero stats bar.
 *
 * Props
 * ─────
 * value : string  — e.g. "170+"
 * label : string  — e.g. "Projects"
 */
interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
---

<div class="flex flex-col items-center py-5 px-4 bg-surface-800/50">
  <span class="text-3xl font-display font-800 text-white leading-none">{value}</span>
  <span class="text-slate-400 text-xs font-medium mt-1.5 tracking-wide">{label}</span>
</div>
