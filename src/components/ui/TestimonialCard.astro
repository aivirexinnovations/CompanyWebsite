---
/**
 * TestimonialCard.astro
 * Star-rated quote card used in the Testimonials section.
 *
 * Props
 * ─────
 * initial : string  — avatar letter (first name initial)
 * name    : string  — reviewer full name
 * company : string  — reviewer company / website
 * stars   : 1–5
 * body    : string  — quote text
 */
interface Props {
  initial: string;
  name:    string;
  company: string;
  stars:   number;
  body:    string;
  href?:   string;
}

const { initial, name, company, stars, body, href } = Astro.props;
const cappedStars = Math.min(5, Math.max(1, Math.round(stars)));
---

<blockquote class="pl-6 flex flex-col gap-5 border-l-2 border-brand-500/20 hover:border-brand-500 transition-colors duration-300">

  <!-- Star rating -->
  <div class="flex gap-0.5" aria-label={`${cappedStars} out of 5 stars`} role="img">
    {Array.from({ length: cappedStars }).map(() => (
      <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
      </svg>
    ))}
    {Array.from({ length: 5 - cappedStars }).map(() => (
      <svg class="w-4 h-4 text-slate-700" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
      </svg>
    ))}
  </div>

  <!-- Quote -->
  <p class="text-slate-300 text-sm leading-relaxed flex-1">
    <span class="text-brand-400 font-display font-700 text-xl leading-none mr-0.5" aria-hidden="true">"</span>{body}<span class="text-brand-400 font-display font-700 text-xl leading-none ml-0.5" aria-hidden="true">"</span>
  </p>

  <!-- Author -->
  <footer class="flex items-center gap-3 pt-3 border-t border-white/6">
    <div
      class="w-9 h-9 rounded-full bg-brand-500/18 border border-brand-500/25 flex items-center justify-center text-brand-300 font-display font-700 text-sm flex-shrink-0"
      aria-hidden="true"
    >
      {initial}
    </div>
    <div>
      {href ? (
        <a href={href} target="_blank" rel="noopener noreferrer" class="text-white text-sm font-semibold not-italic block hover:text-brand-300 transition-colors duration-200">
          <cite class="not-italic">{name}</cite>
        </a>
      ) : (
        <cite class="text-white text-sm font-semibold not-italic block">{name}</cite>
      )}
      <span class="text-slate-500 text-xs">{company}</span>
    </div>
  </footer>
</blockquote>
