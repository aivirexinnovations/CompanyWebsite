---
// LegalLayout.astro – shared wrapper for privacy, terms, cancellation pages
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  keywords?: string;
  lastUpdated?: string;
}

const { title, description, keywords, lastUpdated = 'January 1, 2026' } = Astro.props;
---

<BaseLayout title={title} description={description} keywords={keywords}>
  <Navbar />

  <main id="main-content" class="pt-16">
    <!-- Page hero -->
    <div class="py-16 lg:py-24 text-center relative overflow-hidden">
      <div class="absolute inset-0 -z-10" aria-hidden="true">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-brand-600/10 blur-[80px] rounded-full"></div>
      </div>
      <div class="max-w-3xl mx-auto px-4 sm:px-6" data-reveal="blur">
        <h1 class="text-4xl sm:text-5xl font-display font-800 text-white mb-4">{title}</h1>
        <p class="text-slate-400">Last updated: {lastUpdated}</p>
      </div>
    </div>

    <!-- Content -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 pb-24">
      <article class="prose-legal glass rounded-2xl p-8 sm:p-12">
        <slot />
      </article>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Legal prose styling */
  .prose-legal :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: #f1f5f9;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .prose-legal :global(h3) {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: #e2e8f0;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-legal :global(p) {
    color: #94a3b8;
    line-height: 1.8;
    margin-bottom: 1rem;
    font-size: 0.9375rem;
  }
  .prose-legal :global(ul), .prose-legal :global(ol) {
    color: #94a3b8;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    line-height: 1.8;
    font-size: 0.9375rem;
  }
  .prose-legal :global(li) {
    margin-bottom: 0.4rem;
  }
  .prose-legal :global(a) {
    color: #60a5fa;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-legal :global(strong) {
    color: #e2e8f0;
  }
</style>

<script>
  // Dynamically add data-reveal="blur" to all legal content paragraphs and headers
  // so they fold-in as the user scrolls
  document.addEventListener('DOMContentLoaded', () => {
    const legalElements = document.querySelectorAll('.prose-legal h2, .prose-legal h3, .prose-legal p, .prose-legal ul, .prose-legal ol');
    legalElements.forEach((el, index) => {
      el.setAttribute('data-reveal', 'blur');
    });

    // We need to re-initialize or trigger the observer from BaseLayout
    // if BaseLayout already binds on DOMContentLoaded, this might miss the first frame,
    // but Astro's BaseLayout script executes after this anyway if placed correctly, or
    // we can explicitly observe here.
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          observer.unobserve(entry.target);
        }
      });
    }, {
      root: null,
      rootMargin: '0px 0px -10% 0px',
      threshold: 0.1
    });

    legalElements.forEach(el => observer.observe(el));
  });
</script>
