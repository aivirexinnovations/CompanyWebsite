---
// src/pages/about/index.astro
// Standalone About page. Reuses the homepage + service page design system:
// editorial left aligned column (max-w-5xl), heavy "blur" reveals for headline
// moments, lighter "up"/stagger for the dense grids. Content is drawn from the
// homepage About section and the founder bio, expanded into a full page so it
// earns its own URL in the sitemap and llm files.
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar     from '../../components/Navbar.astro';
import Footer     from '../../components/Footer.astro';
import Badge      from '../../components/ui/Badge.astro';
import Button     from '../../components/ui/Button.astro';

const BOOKING_URL = 'https://calendar.google.com/calendar/appointments/schedules/AcZssZ3sYUI78UrX97keSKdPPhEMyDVTvqApJos040zUwJcm3c_WquNTxBZFlb8m7ltooiunzs_DFHr8?gv=true';
const REVIEW_URL  = 'https://g.page/r/Cfnfxgt2nKD4EAI/review';
const canonical   = 'https://aivirex.in/about';

const stats = [
  { value: '4.8 / 5', label: 'Average Google rating' },
  { value: '83%',     label: 'Clients who return for more work' },
  { value: '2021',    label: 'The year we started' },
  { value: '5 yrs',   label: 'Building software, before and after AI' },
];

const builds = [
  { title: 'AI Visible Websites',        body: 'Researched, built to convert, and wired with tracking so you see what is working. Google and AI assistants recommend it too.' },
  { title: 'AI Agents and Automations',  body: 'Custom agents and workflows that handle leads, support, and operations, built securely with real guardrails.' },
  { title: '0 to 1 Product Studio',      body: 'Idea to launched MVP, with senior product leadership built in alongside the engineering.' },
  { title: 'Custom Software',            body: 'CRMs, internal tools, dashboards, and apps shaped around how your business actually works.' },
];

const steps = [
  { title: 'Book a Call',        body: 'A free strategy call. Tell us where you are stuck, we tell you what is actually possible.' },
  { title: 'Research and Scope', body: 'We study your market, users, and goals, then scope the right solution, not the biggest invoice.' },
  { title: 'Proposal and Quote', body: 'A clear, custom proposal with the timeline and a tailored quote. No hidden fees.' },
  { title: 'Build and Hand Over',body: 'Built in clear milestones, with updates throughout, and handed over with the proof it works.' },
];

const stagger = (i) => `stagger-${(i % 6) + 1}`;

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About AiVirex Innovations',
  url: canonical,
  description: 'AiVirex is a research driven technology studio building AI visible websites, AI agents and automations, custom software, and products from idea to launch.',
  mainEntity: {
    '@type': 'Organization',
    name: 'AiVirex Innovations LLP',
    url: 'https://aivirex.in',
    logo: 'https://aivirex.in/assets/img/logo.png',
    foundingDate: '2021',
    areaServed: ['United States', 'United Kingdom', 'Canada', 'Australia', 'United Arab Emirates', 'India', 'Germany', 'Netherlands']
      .map((name) => ({ '@type': 'Country', name })),
    aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.8', reviewCount: '20', bestRating: '5' },
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',  item: 'https://aivirex.in' },
    { '@type': 'ListItem', position: 2, name: 'About', item: canonical },
  ],
};
---

<BaseLayout
  title="About"
  description="AiVirex is a research driven technology studio building AI visible websites, AI agents and automations, custom software, and products from idea to launch. Serving the USA, UK, Canada, Australia, UAE, and Europe."
  keywords="about AiVirex, AiVirex Innovations, research driven technology studio, software studio Chennai, AI development agency, GEO agency, custom software studio"
  canonicalUrl={canonical}
  includeHreflang={true}
  schemas={[aboutSchema, breadcrumbSchema]}
>
  <Navbar />

  <main id="main-content" class="pt-16">

    <!-- Hero -->
    <section class="pt-14 pb-16 lg:pt-20 lg:pb-24 text-center relative overflow-hidden" aria-labelledby="about-hero-heading">
      <div class="absolute inset-0 -z-10" aria-hidden="true">
        <div class="blob-brand absolute top-1/4 left-1/2 -translate-x-1/2 w-[760px] h-[460px] rounded-full blur-[110px] mix-blend-screen opacity-50 animate-pulse"></div>
        <div class="absolute inset-0 bg-dots opacity-[0.4]"></div>
      </div>

      <!-- Breadcrumb -->
      <nav class="max-w-3xl mx-auto px-4 sm:px-6 mb-7 flex items-center justify-center gap-2 text-xs sm:text-sm text-slate-500" aria-label="Breadcrumb">
        <a href="/" class="inline-flex items-center gap-1.5 hover:text-brand-300 transition-colors font-medium">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.5 1.5 0 012.12 0L22.5 12M4.5 9.75v10.125a1.125 1.125 0 001.125 1.125H9.75v-4.875a1.125 1.125 0 011.125-1.125h2.25a1.125 1.125 0 011.125 1.125V21h4.125a1.125 1.125 0 001.125-1.125V9.75"/></svg>
          Home
        </a>
        <span class="text-slate-600" aria-hidden="true">/</span>
        <span class="text-slate-300">About</span>
      </nav>

      <div class="max-w-3xl mx-auto px-4 sm:px-6" data-sr>
        <div class="flex justify-center mb-6">
          <Badge text="About AiVirex" dot />
        </div>
        <h1
          id="about-hero-heading"
          class="text-4xl sm:text-5xl lg:text-6xl font-display font-700 text-white leading-tight"
        >
          We research first, <span class="text-brand-500">then build.</span>
        </h1>
        <p class="text-slate-300/85 mt-6 text-lg leading-relaxed max-w-2xl mx-auto">
          AiVirex is a research driven technology studio. We figure out what your buyers and your business actually need, then build the website, automation, software, or product that solves it.
        </p>
        <div class="mt-9 flex flex-wrap gap-4 justify-center">
          <Button href={BOOKING_URL} target="_blank" rel="noopener noreferrer" variant="primary" size="lg">
            Book a call
          </Button>
          <Button href="/projects" variant="secondary" size="lg" arrow={false}>
            See our work
          </Button>
        </div>
      </div>
    </section>

    <!-- Editorial column -->
    <div class="max-w-5xl mx-auto px-5 sm:px-6 lg:px-8">

      <!-- Lead -->
      <div class="border-l-2 border-brand-500/60 pl-5 sm:pl-7 py-1" data-sr="left">
        <p class="text-xl sm:text-2xl text-slate-100 font-display font-400 leading-relaxed">
          We build AI visible websites, AI agents and automations, custom software, and products from idea to launch. Real outcomes for businesses and founders, not just deliverables.
        </p>
      </div>

      <!-- Origin -->
      <section class="py-12 lg:py-16">
        <header class="mb-9 max-w-3xl" data-sr="left">
          <p class="eyebrow mb-3 flex items-center gap-3">
            <span class="inline-block w-8 h-px bg-brand-500" aria-hidden="true"></span>
            How it started
          </p>
          <h2 class="text-3xl sm:text-[2.5rem] font-display font-700 text-white leading-[1.12]">One belief, and a problem we kept seeing</h2>
        </header>
        <div class="space-y-5 max-w-3xl" data-sr>
          <p class="text-slate-300/90 leading-relaxed text-lg sm:text-xl">
            It started with one belief. Technology should be accessible to everyone. A business owner without a tech background deserves the same quality access to good software as a funded startup with an in house team.
          </p>
          <p class="text-slate-300/90 leading-relaxed text-lg">
            We kept seeing the same thing. Companies handed a generic template that never converts, or sold AI automation by someone who took a weekend course. Both skip the part that matters, understanding the buyer and the problem before anything gets built.
          </p>
          <p class="text-slate-300/90 leading-relaxed text-lg">
            So we built the studio around research. Study the market and the users first, then build the specific thing that solves the problem. Five years in, that is still how every project runs.
          </p>
        </div>
      </section>

      <!-- Founder callout -->
      <section class="py-8 lg:py-12">
        <div class="glass-brand rounded-3xl px-7 py-9 sm:px-11 sm:py-11 relative overflow-hidden" data-sr>
          <div class="blob-brand absolute -top-1/2 -right-10 w-[400px] h-[300px] rounded-full blur-[80px] opacity-40" aria-hidden="true"></div>
          <p class="eyebrow mb-3 relative">Who builds it</p>
          <p class="text-xl sm:text-2xl lg:text-[1.7rem] font-display font-600 text-white leading-snug relative">
            AiVirex is founder led, with a tech background and a Master's in AI and Data Science behind the work. That means real AI engineering, not prompting, and software that is secure, tested, and made to last.
          </p>
          <p class="text-slate-300/85 mt-5 leading-relaxed relative max-w-2xl">
            You work directly with the people building your project, never a rep who vanishes once the contract is signed. We are a small, senior team, so you always know who is doing the work.
          </p>
        </div>
      </section>

      <!-- Stats -->
      <section class="py-12 lg:py-16" aria-label="By the numbers">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          {stats.map((stat, i) => (
            <div class={`glass-strong rounded-2xl p-6 border-t-2 border-brand-500/40 ${stagger(i)}`} data-sr="zoom">
              <div class="text-3xl sm:text-4xl lg:text-[2.75rem] font-display font-800 text-brand-400 leading-none">{stat.value}</div>
              <div class="text-xs sm:text-sm text-slate-400 mt-3 leading-snug">{stat.label}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- What we build -->
      <section class="py-12 lg:py-16">
        <header class="mb-9 max-w-3xl" data-sr="left">
          <p class="eyebrow mb-3 flex items-center gap-3">
            <span class="inline-block w-8 h-px bg-brand-500" aria-hidden="true"></span>
            What we build
          </p>
          <h2 class="text-3xl sm:text-[2.5rem] font-display font-700 text-white leading-[1.12]">Four ways we take work off your plate</h2>
        </header>
        <div class="grid md:grid-cols-2 gap-4">
          {builds.map((item, i) => (
            <div class={`group flex items-start gap-4 glass rounded-2xl p-5 sm:p-6 card-hover ${stagger(i)}`} data-sr>
              <span class="flex items-center justify-center w-10 h-10 rounded-xl bg-brand-500/12 border border-brand-500/25 text-brand-300 flex-shrink-0 group-hover:bg-brand-500/20 transition-colors">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              </span>
              <div>
                <h3 class="text-base sm:text-lg font-display font-700 text-white mb-1.5 leading-snug">{item.title}</h3>
                <p class="text-sm text-slate-400 leading-relaxed">{item.body}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="mt-8" data-sr>
          <Button href="/services" variant="secondary" size="lg">
            Explore all services
          </Button>
        </div>
      </section>

      <!-- How we work -->
      <section class="py-12 lg:py-16">
        <header class="mb-9 max-w-3xl" data-sr="left">
          <p class="eyebrow mb-3 flex items-center gap-3">
            <span class="inline-block w-8 h-px bg-brand-500" aria-hidden="true"></span>
            How we work
          </p>
          <h2 class="text-3xl sm:text-[2.5rem] font-display font-700 text-white leading-[1.12]">From "I just want this handled" to handled</h2>
        </header>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {steps.map((step, i) => (
            <div class={`relative glass rounded-2xl p-6 pt-7 overflow-hidden ${stagger(i)}`} data-sr>
              <span class="absolute -top-3 -right-1 text-7xl font-display font-800 text-white/[0.04] select-none leading-none" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <div class="relative">
                <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-brand-500/15 border border-brand-500/30 text-brand-300 text-sm font-bold font-mono mb-4">{i + 1}</span>
                <h3 class="text-base font-display font-700 text-white mb-2 leading-snug">{step.title}</h3>
                <p class="text-sm text-slate-400 leading-relaxed">{step.body}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <div class="divider-x my-4" aria-hidden="true"></div>

      <!-- Where we work -->
      <section class="py-12 lg:py-16" aria-label="Where we work">
        <div class="glass rounded-3xl px-6 py-9 sm:px-11 sm:py-11" data-sr>
          <h2 class="text-2xl sm:text-3xl font-display font-700 text-white leading-tight">Where we work</h2>
          <p class="text-slate-400 mt-3 max-w-2xl leading-relaxed text-lg">
            We work fully remote with businesses across the USA, UK, Canada, Australia, UAE, and Europe, alongside clients here in India. We run in your timezone with clear milestones and async updates, so distance never slows the work down.
          </p>
        </div>
      </section>
    </div>

    <!-- Closing CTA -->
    <section class="pt-6 pb-20 lg:pb-28" aria-label="Get started">
      <div class="max-w-4xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="glass-brand rounded-3xl px-6 py-12 sm:px-12 sm:py-14 text-center relative overflow-hidden" data-sr>
          <div class="blob-brand absolute -top-1/2 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full blur-[90px] opacity-40" aria-hidden="true"></div>
          <h2 class="text-3xl sm:text-4xl font-display font-700 text-white leading-tight relative">Let's build something that works</h2>
          <p class="text-slate-300 mt-4 max-w-xl mx-auto relative">Tell us where you are stuck and we will tell you what is actually possible, then scope it and give you a clear, tailored quote.</p>
          <div class="mt-8 flex flex-wrap gap-4 justify-center relative">
            <Button href={BOOKING_URL} target="_blank" rel="noopener noreferrer" variant="primary" size="lg">
              Book a free strategy call
            </Button>
            <Button href={REVIEW_URL} target="_blank" rel="noopener noreferrer" variant="secondary" size="lg" arrow={false}>
              Drop us a review
            </Button>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
