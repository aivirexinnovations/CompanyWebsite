<style>
  /* Feature-row visuals — lightweight CSS/SVG animations (no Lottie/JS) */
  .fx-card { animation: fx-bob 4s ease-in-out infinite; }
  @keyframes fx-bob {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-4px); }
  }

  .fx-dot { animation: fx-pulse 2s ease-in-out infinite; }
  @keyframes fx-pulse {
    0%, 100% { opacity: 1;   box-shadow: 0 0 0 0 rgba(52,211,153,0.5); }
    50%      { opacity: 0.4; box-shadow: 0 0 0 4px rgba(52,211,153,0); }
  }

  .fx-scanline { animation: fx-scan 2.4s ease-in-out infinite; }
  @keyframes fx-scan {
    0%, 100% { top: 4%; }
    50%      { top: 92%; }
  }

  .fx-caret { animation: fx-blink 1s step-end infinite; }
  @keyframes fx-blink { 50% { opacity: 0; } }

  .fx-check { stroke-dasharray: 24; stroke-dashoffset: 24; animation: fx-draw 3s ease-in-out infinite; }
  @keyframes fx-draw {
    0%, 40%  { stroke-dashoffset: 24; opacity: 0; }
    55%, 90% { stroke-dashoffset: 0;  opacity: 1; }
    100%     { stroke-dashoffset: 24; opacity: 0; }
  }

  .fx-bubble {
    animation: fx-pop 4.5s ease-in-out infinite;
    opacity: 0;
    transform: translateY(8px) scale(0.96);
  }
  @keyframes fx-pop {
    0%      { opacity: 0; transform: translateY(8px) scale(0.96); }
    8%, 85% { opacity: 1; transform: translateY(0) scale(1); }
    100%    { opacity: 0; transform: translateY(8px) scale(0.96); }
  }

  .fx-bar { animation: fx-grow 3s ease-in-out infinite; transform-origin: bottom; }
  @keyframes fx-grow {
    0%, 100% { height: var(--fx-min, 30%); }
    50%      { height: var(--fx-max, 80%); }
  }

  .fx-orbit      { animation: fx-rotate 18s linear infinite; }
  .fx-orbit-item { animation: fx-counter-rotate 18s linear infinite; }
  @keyframes fx-rotate         { to { transform: rotate(360deg); } }
  @keyframes fx-counter-rotate { to { transform: rotate(-360deg); } }

  .fx-arrow { animation: fx-arrow-slide 2s ease-in-out infinite; }
  @keyframes fx-arrow-slide {
    0%, 100% { transform: translateX(0);  opacity: 0.6; }
    50%      { transform: translateX(4px); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .fx-card, .fx-dot, .fx-scanline, .fx-caret, .fx-check,
    .fx-bubble, .fx-bar, .fx-orbit, .fx-orbit-item, .fx-arrow {
      animation: none;
    }
    /* Restore a visible "settled" state for effects whose resting
       styles are otherwise an animation-start (invisible) frame */
    .fx-bubble {
      opacity: 1;
      transform: none;
    }
    .fx-bar {
      height: var(--fx-max, 80%);
    }
    .fx-check {
      stroke-dashoffset: 0;
      opacity: 1;
    }
  }
</style>

<script>
  // Billing toggle + member-count slider script
  const billingBtns = document.querySelectorAll('.billing-btn');
  const facilityPriceEl = document.getElementById('facility-price');
  const displayPriceEl = document.getElementById('display-price');
  const planNameEl = document.getElementById('plan-name');
  const studentSlider = document.getElementById('student-slider');
  const sliderValueEl = document.getElementById('slider-value');

  const plans = {
    monthly:    { facility: '350',  monthlyEquivalent: 350,  name: 'Quick Stride Plan' },
    quarterly:  { facility: '960',  monthlyEquivalent: 320,  name: 'Quick Leap Plan' },
    halfyearly: { facility: '1740', monthlyEquivalent: 290,  name: 'Halftime Plan' },
    yearly:     { facility: '2999', monthlyEquivalent: 250,  name: 'All Season Plan' },
  };

  let currentPlan = 'monthly';

  function updatePricing() {
    const plan = plans[currentPlan];
    if (!plan || !displayPriceEl || !facilityPriceEl || !planNameEl || !studentSlider) return;
    const students = parseInt(studentSlider.value, 10) || 1;
    displayPriceEl.textContent  = (plan.monthlyEquivalent / students).toFixed(2);
    facilityPriceEl.textContent = plan.facility;
    planNameEl.textContent      = plan.name;
  }

  billingBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      // Toggle active styles
      billingBtns.forEach((b) => {
        b.classList.remove('bg-brand-500', 'text-white', 'shadow-lg', 'shadow-brand-500/25');
        b.classList.add('glass', 'text-slate-400');
      });
      btn.classList.add('bg-brand-500', 'text-white', 'shadow-lg', 'shadow-brand-500/25');
      btn.classList.remove('glass', 'text-slate-400');

      currentPlan = btn.getAttribute('data-plan') || 'monthly';
      updatePricing();
    });
  });

  if (studentSlider) {
    studentSlider.addEventListener('input', () => {
      if (sliderValueEl) sliderValueEl.textContent = studentSlider.value;
      updatePricing();
    });
  }

  updatePricing();

  // Hero Spotlight Tracking
  const hero = document.getElementById('hero');
  const spotlight = document.getElementById('hero-spotlight');

  if (hero && spotlight) {
    hero.addEventListener('mousemove', (e) => {
      const rect = hero.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      
      spotlight.style.left = `${x}px`;
      spotlight.style.top = `${y}px`;
      spotlight.style.opacity = '0.6';
    });

    hero.addEventListener('mouseleave', () => {
      spotlight.style.opacity = '0';
    });
  }

  // Why Us Horizontal Scroll Translation
  const whyScrollContainer = document.querySelector('.horizontal-scroll-container');
  const whyTrack = document.getElementById('why-horizontal-track');

  if (whyScrollContainer && whyTrack) {
    // Basic sticky scroll implementation
    window.addEventListener('scroll', () => {
      const rect = whyScrollContainer.getBoundingClientRect();
      const scrollPercent = Math.max(0, Math.min(1, -rect.top / (rect.height - window.innerHeight)));
      
      // Calculate how far to translate (track width - viewport width)
      const maxTranslate = whyTrack.scrollWidth - window.innerWidth + 200; // adding padding
      const translateX = scrollPercent * -maxTranslate;
      
      whyTrack.style.transform = `translateX(${translateX}px)`;
    });
  }
</script>
