---
// src/pages/attendify/index.astro
import BaseLayout    from '../../layouts/BaseLayout.astro';
import Navbar        from '../../components/Navbar.astro';
import Footer        from '../../components/Footer.astro';

import Button        from '../../components/ui/Button.astro';
import Badge         from '../../components/ui/Badge.astro';
import Card          from '../../components/ui/Card.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import FeatureRow    from '../../components/ui/FeatureRow.astro';
import FAQList       from '../../components/ui/FAQList.astro';
import WhatsAppFloat from '../../components/ui/WhatsAppFloat.astro';

/* ── Data ───────────────────────────────────────────────── */

const featureRows = [
  {
    title: 'Membership Management',
    body:  'Ditch the register and spreadsheets. Replace paper records with a clean, easy-to-use digital system. Add, view, and manage all member info anytime, from anywhere on any device.',
    flip: false,
  },
  {
    title: 'QR-Based Attendance Tracking',
    body:  "Take attendance the smart way. Members scan a QR code on arrival, it's time-stamped automatically — no manual entry, no confusion. Robust filters let admins view daily, weekly, or monthly records at a glance.",
    flip: true,
  },
  {
    title: 'Custom Forms & Data Collection',
    body:  "Say goodbye to one-size-fits-all forms. Whether you're a gym tracking BMI or a dance studio tracking skill levels, custom fields let you collect exactly the data you need — nothing more.",
    flip: false,
  },
  {
    title: 'Integrated Communication Channels',
    body:  'Send bulk or personalised reminders via SMS, Email, or WhatsApp to students and members. Set up fee reminders, promotional messages, or check-in nudges with ready-made templates.',
    flip: true,
  },
  {
    title: 'Income & Expense Tracking',
    body:  'Keep a clear eye on your finances. Easily monitor spending and income for better budgeting. Make informed, data-backed financial decisions without switching tools.',
    flip: false,
  },
  {
    title: 'Comprehensive Value, One Platform',
    body:  'Attendify is a complete management solution — attendance, renewals, reminders, analytics, and communication in one place without bloat. A tool, not a partner that charges more as you grow.',
    flip: true,
  },
];

const whyUs = [
  { title: 'Innovative & Future-Ready', body: 'Rooted in agile startup culture, we continually enhance the software driven by real user feedback.' },
  { title: 'Versatile & Flexible',      body: 'Transcends industry boundaries — gyms, pools, martial arts, dance, coaching centres, and more.' },
  { title: 'Pocket Friendly',           body: "Innovation doesn't have to be expensive. Premium quality at an affordable, transparent price." },
  { title: 'Built by Athletes',         body: 'Attendify was built by athletes and coaches who struggled with paper registers — so we fixed it.' },
];

const billingPlans = [
  { id: 'monthly',    label: 'Quick Stride', duration: 'Monthly',  price: '3.50',  facility: '350',  name: 'Quick Stride Plan' },
  { id: 'quarterly',  label: 'Quick Leap',   duration: '3 Months', price: '3.20',  facility: '960',  name: 'Quick Leap Plan'   },
  { id: 'halfyearly', label: 'Halftime',     duration: '6 Months', price: '2.90',  facility: '1740', name: 'Halftime Plan'     },
  { id: 'yearly',     label: 'All Season',   duration: 'Yearly',   price: '2.50',  facility: '2999', name: 'All Season Plan',  badge: 'Save 28%' },
];

const pricingFeatures = [
  'Smart Attendance Tracking',
  'Fee Payment Reminders',
  'Unlimited Marketing Messages',
  'Custom Message Templates',
  'Income & Expense Tracker',
  'Business Intelligence Dashboard',
];

const faqs = [
  { q: 'What is Attendify and who is it for?',              a: 'Attendify is a membership and attendance manager for gyms, fitness studios, yoga and martial arts schools, dance academies, and coaching centres. It replaces paper registers with a simple app that works on any smartphone.' },
  { q: 'How much does Attendify cost? Is there a free tier?', a: 'Start on the free tier for core tracking. As you grow, paid plans unlock analytics, automated reminders, and multi-location support at a low monthly rate.' },
  { q: 'How does attendance tracking work?',                a: 'Members scan a QR code when they arrive. Check-ins are time-stamped automatically, and you can view daily, weekly, or monthly attendance from anywhere.' },
  { q: 'Can I import existing member data from Excel?',     a: 'Yes. Upload CSV or Excel files and migrate your member database without losing information. We guide you through the process during onboarding.' },
  { q: 'Does Attendify send automatic renewal reminders?',  a: 'Attendify tracks expiry dates and sends reminders via SMS, Email, or WhatsApp before memberships lapse — reducing churn and saving manual follow-up.' },
  { q: 'Is my member data secure?',                         a: 'Data is encrypted, stored on secure cloud infrastructure, and never shared with third parties. You retain full ownership of your member information.' },
  { q: 'Can I manage multiple locations?',                  a: 'Yes. Multi-location management lets you see performance across branches or drill into each site from a single dashboard.' },
  { q: 'What makes Attendify different?',                   a: "It's built specifically for recurring membership businesses, not generic time-tracking. Attendance, renewals, reminders, analytics, and communication — all in one place, without bloat." },
];

import HeroClarityCanvas from '../../components/ui/HeroClarityCanvas.astro';

// Decorative "data cell" coordinates for the QR-code visual (feature row 2)
const qrDataCells = [
  [32, 6], [40, 6], [58, 6], [66, 6],
  [6, 32], [6, 40], [6, 58], [6, 66],
  [88, 32], [88, 46], [88, 60],
  [32, 88], [46, 88], [60, 88],
  [32, 32], [44, 38], [56, 30], [38, 50], [50, 56],
  [62, 44], [34, 62], [46, 68], [60, 62], [68, 50], [40, 42], [52, 32],
];

---

<BaseLayout
  title="Attendify | Gym & Membership Management App (India)"
  description="Manage your gym, yoga studio, or sports academy from your phone. QR code attendance, automated WhatsApp fee reminders, and income tracking. Free download."
  keywords="gym management software India, membership management app, QR code attendance tracking, yoga studio software, sports academy management app, fitness center software, automated fee reminders, WhatsApp fee reminder app"
  canonicalUrl="https://aivirex.in/attendify"
  includeHreflang={true}
  geoRegion="IN"
  geoPlacename="India"
  ogImage="/assets/img/black%20bg.png"
  schemas={[
    {
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'Attendify',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Android',
      offers: {
        '@type': 'Offer',
        price: '250',
        priceCurrency: 'INR'
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.8',
        reviewCount: '150'
      },
      areaServed: [
        { '@type': 'Country', name: 'India' },
        { '@type': 'Place', name: 'Worldwide' }
      ],
      description: 'Membership management app for gyms, yoga studios, and sports academies. Features QR attendance tracking, automated fee reminders, and income management.',
      url: 'https://aivirex.in/attendify',
    },
    {
      '@context': 'https://schema.org',
      '@type': 'Product',
      name: 'Attendify - Membership Manager',
      image: 'https://aivirex.in/assets/img/Project%20Mockups/Project_Attendify.png',
      description: 'Replace your attendance register with Attendify. Scan member QR codes, track expiry dates, send automated WhatsApp reminders, and monitor gym income.',
      brand: {
        '@type': 'Brand',
        name: 'AiVirex'
      },
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.8',
        reviewCount: '150'
      },
      areaServed: [
        { '@type': 'Country', name: 'India' },
        { '@type': 'Place', name: 'Worldwide' }
      ],
      offers: {
        '@type': 'Offer',
        url: 'https://play.google.com/store/apps/details?id=com.aivirex.attendify',
        priceCurrency: 'INR',
        price: '250',
        availability: 'https://schema.org/InStock',
        seller: {
          '@type': 'Organization',
          name: 'AiVirex Innovations LLP'
        }
      }
    }
  ]}
>
  <Navbar />

  <main id="main-content">

    <!-- ═══════════════════════════════════════════
         1 · HERO
    ═══════════════════════════════════════════ -->
    <section id="hero" class="relative min-h-screen flex items-center pt-16 overflow-hidden bg-[#03060f]" aria-label="Attendify hero">
      <HeroClarityCanvas />
      <!-- Left legibility wash -->
      <div class="absolute inset-0 bg-gradient-to-r from-[#03060f] via-[#03060f]/70 to-transparent pointer-events-none" aria-hidden="true"></div>
      <!-- Film grain -->
      <div class="absolute inset-0 bg-grain opacity-40 mix-blend-overlay pointer-events-none" aria-hidden="true"></div>
      <!-- Bottom fade into next section -->
      <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-surface-base to-transparent pointer-events-none" aria-hidden="true"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 w-full relative z-10">
        <div class="grid lg:grid-cols-2 gap-14 items-center">

          <!-- Text -->
          <div data-reveal="blur">
            <Badge text="Available on Android" color="emerald" dot class="mb-5" />
            <h1 class="heading-xl text-white mb-5">
              Aivirex Attendify<br />
              <span class="text-brand-500">Membership Made Simple</span>
            </h1>
            <p class="text-slate-400 text-lg leading-relaxed mb-8">
              Your All-in-One Membership Manager. Replace paper registers with a smart, connected platform your entire team will actually enjoy using.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 mb-7">
              <Button href="https://play.google.com/store/apps/details?id=com.aivirex.attendify" target="_blank" rel="noopener noreferrer" variant="primary" size="lg" id="attendify-download-cta" arrow={false}>
                <!-- Play Store icon -->
                <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M3.18 23.76a2 2 0 0 0 2.16-.18l12.31-7.1-2.93-2.93-11.54 10.21zM.63 1.26A2 2 0 0 0 0 2.82v18.36a2 2 0 0 0 .63 1.56l.07.06 10.28-10.27v-.24L.7 1.2l-.07.06zm17.55 10.4-3.31-1.91-3.3 3.3 3.3 3.31 3.32-1.92a2 2 0 0 0 0-2.78zM5.34.42 17.65 7.52l-2.93 2.93L3.18.18A2 2 0 0 1 5.34.42z"/>
                </svg>
                Download on Google Play
              </Button>
              <Button href="#pricing" variant="secondary" size="lg" id="attendify-pricing-cta" arrow={false}>
                View Pricing
              </Button>
            </div>

            <!-- Social proof badge -->
            <div class="mt-8">
              <a href="https://www.producthunt.com/posts/attendify-3?embed=true&utm_source=badge-featured&utm_medium=badge&utm_souce=badge-attendify-3" target="_blank" rel="noopener noreferrer" class="inline-block hover:opacity-90 transition-opacity duration-200">
                <img
                  src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=591398&theme=dark"
                  alt="Attendify - All in one membership management app | Product Hunt"
                  class="w-[250px] h-[54px]"
                  width="250"
                  height="54"
                  loading="lazy"
                />
              </a>
            </div>
          </div>

          <!-- Video / visual -->
          <div class="hidden lg:flex justify-center w-full relative z-10" data-reveal="blur">
            <div class="w-full aspect-video rounded-2xl overflow-hidden shadow-2xl border border-white/10 glow">
              <iframe class="w-full h-full object-cover"
                src="https://www.youtube.com/embed/7CgVvtJrYtM?si=HW6QjpQgRn0SXUGy&modestbranding=1&rel=0&showinfo=0&autohide=1"
                title="Introduction To Attendify"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen></iframe>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         2 · FEATURES (6 alternating rows)
    ═══════════════════════════════════════════ -->
    <section id="features" class="section" aria-labelledby="features-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div data-reveal="blur">
          <SectionHeader
            id="features-heading"
            heading={`Everything to run <span class="text-brand-500">your facility</span>`}
            subheading="Attendify combines attendance tracking, payment reminders, and membership management in one simple app."
          />
        </div>

        <div class="relative max-w-5xl mx-auto pb-24 pt-12">
          {featureRows.map((f, i) => (
            <div class:list={[
              'sticky flex flex-col md:flex-row gap-12 items-center bg-surface-900/80 backdrop-blur-3xl border border-white/5 p-10 lg:p-16 rounded-[2.5rem] shadow-2xl transition-all duration-500 ease-out',
              i < featureRows.length - 1 ? 'mb-[50vh]' : 'mb-0',
            ]} style={`top: ${100 + i*25}px; z-index: ${i}`}>
              
              <!-- Content -->
              <div class="flex-1 order-2 md:order-1">
                <div class="text-brand-500 font-display font-800 text-6xl mb-6 opacity-20">0{i+1}</div>
                <h3 class="text-3xl sm:text-4xl font-display font-700 text-white mb-6">{f.title}</h3>
                <p class="text-slate-400 text-lg leading-relaxed">{f.body}</p>
              </div>

              <!-- Visual -->
              <div class="flex-1 w-full order-1 md:order-2">
                <div class="w-full aspect-[4/3] rounded-[2rem] bg-gradient-to-br from-surface-800 to-surface-base border border-white/5 shadow-inner overflow-hidden relative group flex items-center justify-center p-8">
                  <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4wNSkiLz48L3N2Zz4=')] opacity-50 group-hover:scale-110 transition-transform duration-1000"></div>

                  {/* 0: Membership Management — animated member cards */}
                  {i === 0 && (
                    <div class="relative z-10 w-full max-w-[280px] space-y-3">
                      {[0, 1, 2].map((row) => (
                        <div class="fx-card flex items-center gap-3 bg-white/5 border border-white/10 rounded-xl p-3" style={`animation-delay:${row * 0.25}s`}>
                          <div class="w-9 h-9 rounded-full bg-brand-500/25 border border-brand-400/40 flex-shrink-0 flex items-center justify-center">
                            <svg class="w-4 h-4 text-brand-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                          </div>
                          <div class="flex-1 space-y-1.5">
                            <div class="h-2 bg-white/15 rounded-full w-3/4"></div>
                            <div class="h-2 bg-white/8 rounded-full w-1/2"></div>
                          </div>
                          <div class="fx-dot w-2 h-2 rounded-full bg-emerald-400 flex-shrink-0" style={`animation-delay:${row * 0.25}s`}></div>
                        </div>
                      ))}
                    </div>
                  )}

                  {/* 1: QR-Based Attendance Tracking — scanning QR code */}
                  {i === 1 && (
                    <div class="relative z-10 w-48 h-48 rounded-2xl bg-white p-4 shadow-xl overflow-hidden">
                      <svg viewBox="0 0 100 100" class="w-full h-full" fill="#0f172a" aria-hidden="true">
                        <rect x="4" y="4" width="22" height="22"/>
                        <rect x="9" y="9" width="12" height="12" fill="#fff"/>
                        <rect x="13" y="13" width="4" height="4" fill="#0f172a"/>
                        <rect x="74" y="4" width="22" height="22"/>
                        <rect x="79" y="9" width="12" height="12" fill="#fff"/>
                        <rect x="83" y="13" width="4" height="4" fill="#0f172a"/>
                        <rect x="4" y="74" width="22" height="22"/>
                        <rect x="9" y="79" width="12" height="12" fill="#fff"/>
                        <rect x="13" y="83" width="4" height="4" fill="#0f172a"/>
                        {qrDataCells.map(([x, y]) => (
                          <rect x={x} y={y} width="6" height="6"/>
                        ))}
                      </svg>
                      <div class="fx-scanline absolute left-0 right-0 h-1 rounded-full bg-brand-400 shadow-[0_0_12px_2px_rgba(15,144,226,0.8)]"></div>
                    </div>
                  )}

                  {/* 2: Custom Forms & Data Collection — form fields + checkbox */}
                  {i === 2 && (
                    <div class="relative z-10 w-full max-w-[280px] space-y-4 bg-white/5 border border-white/10 rounded-xl p-5">
                      <div class="space-y-1.5">
                        <div class="h-2 w-16 bg-white/20 rounded-full"></div>
                        <div class="h-8 rounded-lg border border-white/15 bg-white/5 flex items-center px-3">
                          <span class="fx-caret w-px h-3 bg-brand-400"></span>
                        </div>
                      </div>
                      <div class="space-y-1.5">
                        <div class="h-2 w-20 bg-white/20 rounded-full"></div>
                        <div class="h-8 rounded-lg border border-white/15 bg-white/5"></div>
                      </div>
                      <div class="flex items-center gap-2 pt-1">
                        <div class="w-5 h-5 rounded-md border border-brand-400/50 flex items-center justify-center flex-shrink-0">
                          <svg class="fx-check w-3 h-3 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                            <polyline points="20 6 9 17 4 12"/>
                          </svg>
                        </div>
                        <div class="h-2 w-24 bg-white/15 rounded-full"></div>
                      </div>
                    </div>
                  )}

                  {/* 3: Integrated Communication Channels — chat bubbles */}
                  {i === 3 && (
                    <div class="relative z-10 w-full max-w-[280px] flex flex-col gap-2.5">
                      <div class="fx-bubble self-start max-w-[75%] bg-white/8 border border-white/10 rounded-2xl rounded-bl-sm px-3.5 py-2.5" style="animation-delay:0s">
                        <div class="h-2 w-32 bg-white/20 rounded-full"></div>
                      </div>
                      <div class="fx-bubble self-end max-w-[75%] bg-brand-500/25 border border-brand-400/30 rounded-2xl rounded-br-sm px-3.5 py-2.5 flex items-center gap-1.5" style="animation-delay:0.6s">
                        <div class="h-2 w-24 bg-white/25 rounded-full"></div>
                        <svg class="w-3 h-3 text-brand-300 flex-shrink-0" fill="currentColor" viewBox="0 0 16 15" aria-hidden="true">
                          <path d="M15.01 3.316l-.478-.372a.365.365 0 00-.51.063L8.95 9.454 6.84 7.343a.365.365 0 00-.516 0l-.453.453a.364.364 0 000 .515l2.834 2.834a.366.366 0 00.516 0l6.802-8.83a.365.365 0 00-.013-.499z"/>
                        </svg>
                      </div>
                      <div class="fx-bubble self-start max-w-[75%] bg-white/8 border border-white/10 rounded-2xl rounded-bl-sm px-3.5 py-2.5" style="animation-delay:1.2s">
                        <div class="h-2 w-20 bg-white/20 rounded-full"></div>
                      </div>
                    </div>
                  )}

                  {/* 4: Income & Expense Tracking — animated bar chart */}
                  {i === 4 && (
                    <div class="relative z-10 w-full max-w-[260px]">
                      <div class="flex items-center gap-2 mb-4 text-brand-400">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l6-6 4 4 8-8M21 7v6h-6"/></svg>
                        <span class="text-xs font-semibold uppercase tracking-wider">Income trend</span>
                      </div>
                      <div class="h-40 flex items-end justify-between gap-3">
                        <div class="fx-bar flex-1 rounded-t-lg bg-gradient-to-t from-brand-500/20 to-brand-400/70" style="--fx-min:30%; --fx-max:70%; animation-delay:0s"></div>
                        <div class="fx-bar flex-1 rounded-t-lg bg-gradient-to-t from-brand-500/20 to-brand-400/70" style="--fx-min:45%; --fx-max:95%; animation-delay:0.2s"></div>
                        <div class="fx-bar flex-1 rounded-t-lg bg-gradient-to-t from-brand-500/20 to-brand-400/70" style="--fx-min:35%; --fx-max:80%; animation-delay:0.4s"></div>
                        <div class="fx-bar flex-1 rounded-t-lg bg-gradient-to-t from-brand-500/20 to-brand-400/70" style="--fx-min:55%; --fx-max:100%; animation-delay:0.6s"></div>
                        <div class="fx-bar flex-1 rounded-t-lg bg-gradient-to-t from-brand-500/20 to-brand-400/70" style="--fx-min:30%; --fx-max:75%; animation-delay:0.8s"></div>
                      </div>
                    </div>
                  )}

                  {/* 5: Comprehensive Value, One Platform — orbiting hub */}
                  {i === 5 && (
                    <div class="relative z-10 w-56 h-56 flex items-center justify-center">
                      <div class="w-14 h-14 rounded-2xl bg-brand-500/25 border border-brand-400/40 flex items-center justify-center">
                        <svg class="w-7 h-7 text-brand-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"/></svg>
                      </div>
                      <div class="fx-orbit absolute inset-0">
                        <div class="absolute top-0 left-1/2 -translate-x-1/2">
                          <div class="fx-orbit-item w-10 h-10 rounded-xl bg-white/8 border border-white/15 flex items-center justify-center text-slate-300">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                          </div>
                        </div>
                        <div class="absolute bottom-0 left-1/2 -translate-x-1/2">
                          <div class="fx-orbit-item w-10 h-10 rounded-xl bg-white/8 border border-white/15 flex items-center justify-center text-slate-300">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                          </div>
                        </div>
                        <div class="absolute top-1/2 left-0 -translate-y-1/2">
                          <div class="fx-orbit-item w-10 h-10 rounded-xl bg-white/8 border border-white/15 flex items-center justify-center text-slate-300">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                          </div>
                        </div>
                        <div class="absolute top-1/2 right-0 -translate-y-1/2">
                          <div class="fx-orbit-item w-10 h-10 rounded-xl bg-white/8 border border-white/15 flex items-center justify-center text-slate-300">
