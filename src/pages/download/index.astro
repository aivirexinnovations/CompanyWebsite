---
// src/pages/download/index.astro
// Redirect page → Play Store (mirrors production download.html)
// Astro static redirect using meta refresh + JS for instant redirect
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redirecting to Attendify on Play Store…</title>
    <meta name="robots" content="noindex, nofollow" />
    <!-- Instant JS redirect -->
    <script>
      window.location.replace('https://play.google.com/store/apps/details?id=com.aivirex.attendify');
    </script>
    <!-- Fallback meta refresh for no-JS -->
    <meta http-equiv="refresh" content="0;url=https://play.google.com/store/apps/details?id=com.aivirex.attendify" />
  </head>
  <body style="background:#070d1a;color:#94a3b8;font-family:system-ui,sans-serif;display:flex;min-height:100vh;align-items:center;justify-content:center;text-align:center;padding:1rem;">
    <div>
      <p style="font-size:1.25rem;margin-bottom:1rem;">Redirecting to Play Store…</p>
      <p style="font-size:0.875rem;">
        If you are not redirected automatically,
        <a href="https://play.google.com/store/apps/details?id=com.aivirex.attendify" style="color:#38adf6;">click here</a>.
      </p>
    </div>
  </body>
</html>
