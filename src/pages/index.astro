<script>
  // ════════════ CLARITY HERO — lens of clarity ════════════
  (() => {
    const hero = document.getElementById('hero');
    if (!hero) return;

    // — decode headline: chaos → clarity (re-runs on hover) —
    const h1 = hero.querySelector('[data-scramble]');
    if (h1) {
      const lines = (h1.dataset.final || h1.textContent || '').split('|');
      const glyphs = '!<>-_\\/[]{}=+*^?#§$%&';
      let timer = 0;
      const run = () => {
        window.clearInterval(timer);
        const settle = lines.map((l) => l.split('').map(() => 6 + Math.floor(Math.random() * 28)));
        let f = 0;
        timer = window.setInterval(() => {
          h1.innerHTML = lines.map((l, li) => l.split('').map((ch, ci) => {
            if (ch === ' ') return '&nbsp;';
            if (f >= settle[li][ci]) return ch;
            return `<span class="sc">${glyphs[(Math.random() * glyphs.length) | 0]}</span>`;
          }).join('')).join('<br>');
          if (++f > 42) window.clearInterval(timer);
        }, 42);
      };
      run();
      h1.addEventListener('mouseenter', run);
    }
  })();
</script>

<script>
  // Hero Background Cursor-Tracking Spotlight
  const heroBg = document.getElementById('hero-bg');
  if (heroBg) {
    document.addEventListener('mousemove', (e) => {
      const x = (e.clientX / window.innerWidth) * 100;
      const y = (e.clientY / window.innerHeight) * 100;
      heroBg.style.setProperty('--mouse-x', `${x}%`);
      heroBg.style.setProperty('--mouse-y', `${y}%`);
    });
  }

  // Hero Dashboard: animated count-up for stat numbers
  const statEls = document.querySelectorAll('#hero-dashboard [data-count-to]');
  if (statEls.length) {
    const animateCount = (el) => {
      const raw = el.dataset.countTo || '';
      const match = raw.match(/^(\d+)(.*)$/);
      if (!match) { el.textContent = raw; return; }
      const target = parseInt(match[1], 10);
      const suffix = match[2];
      const duration = 1400;
      const start = performance.now();
      const tick = (now) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(target * eased) + suffix;
        if (progress < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      statEls.forEach((el) => { el.textContent = el.dataset.countTo || ''; });
    } else {
      const statObserver = new IntersectionObserver((entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animateCount(entry.target);
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.4 });
      statEls.forEach((el) => statObserver.observe(el));
    }
  }

  // Bending Scroll Track + Laser
  const trackContainer = document.getElementById('scroll-track-container');
  const trackSvg       = document.getElementById('scroll-track-svg');
  const trackPath      = document.getElementById('scroll-track-path');
  const laserCore      = document.getElementById('scroll-laser-core');
  const laserLayers    = [
    document.getElementById('scroll-laser-glow-3'),
    document.getElementById('scroll-laser-glow-2'),
    document.getElementById('scroll-laser-glow-1'),
    document.getElementById('scroll-laser-halo'),
    laserCore,
  ].filter(Boolean);
  const servicesList   = document.getElementById('services-focus-list');
  const aboutSection   = document.getElementById('about');
  const whySection     = document.getElementById('why-choose-us');
  const whyHeading     = document.getElementById('why-heading');
  const faqSection     = document.getElementById('faq');
  const faqHeading     = document.getElementById('faq-heading');

  const CORNER_RADIUS = 36;
  const BEND_HEIGHT   = 80; // vertical run on each side of a left/right bend
  const LASER_LENGTH  = 200;
  const SAMPLE_STEP   = 8; // px spacing for the precomputed geometry table

  // Precomputed [{ len, x, y }] along the whole track, built once in
  // buildScrollPath(). Lets scroll updates do plain array math instead of
  // calling the (surprisingly expensive) native getPointAtLength() every
  // frame, which was the cause of the scroll-smoothness regression.
  let pathSamples = [];

  // Sections/headings that get a "laser illumination" glow as the beam
  // passes behind them, with bounds (relative to trackContainer's top-left)
  // recomputed on layout changes.
  //
  // - "section" targets (#about, #projects, #testimonials) already have an
  //   opaque background + `.laser-glow-spot` child of their own.
  // - "title" targets (SectionHeader with `laserGlow`) have no background of
  //   their own — a floating patch (opaque + glow) is created for them in
  //   #laser-glow-patches, sized to the heading's box. That patch sits at
  //   -z-[15] — above the track (-z-50) but below section-local decoratives
  //   like dot-grid backgrounds (-z-10) — so it occludes the track without
  //   covering those decorations.
  const laserGlowPatches = document.getElementById('laser-glow-patches');
  const laserGlowTargets = Array.from(document.querySelectorAll('[data-laser-glow-target]')).map((el) => {
    if (el.dataset.laserGlowTarget === 'title' && laserGlowPatches) {
      // Soft elliptical vignette instead of a flat fill — occludes the
      // track through the heading's core but fades to transparent on
      // every side, so there's no straight edge anywhere (just a rounded
      // glow blob) against the section's own background/texture.
      const patch = document.createElement('div');
      patch.className = 'absolute';
      patch.style.background = 'radial-gradient(ellipse 50% 50% at center, var(--color-surface-base), var(--color-surface-base) 45%, transparent 75%)';
      const layer = document.createElement('div');
      layer.className = 'laser-glow-layer';
      const spot = document.createElement('div');
      spot.className = 'laser-glow-spot--title';
      layer.appendChild(spot);
      patch.appendChild(layer);
      laserGlowPatches.appendChild(patch);
      return { el, spot, patch, top: 0, left: 0, bottom: 0, spotW: 0, spotH: 0, isTitle: true };
    }
    return { el, spot: el.querySelector('[data-laser-glow-spot]'), patch: null, top: 0, left: 0, bottom: 0, spotW: 700, spotH: 700, isTitle: false };
  });

  function linePoints(x1, y1, x2, y2) {
    const dist = Math.hypot(x2 - x1, y2 - y1);
    const steps = Math.max(1, Math.round(dist / SAMPLE_STEP));
    const pts = [];
    for (let i = 1; i <= steps; i++) {
      const t = i / steps;
      pts.push({ x: x1 + (x2 - x1) * t, y: y1 + (y2 - y1) * t });
    }
    return pts;
  }

  function quadPoints(x1, y1, cx, cy, x2, y2) {
    const steps = 8;
    const pts = [];
    for (let i = 1; i <= steps; i++) {
      const t = i / steps;
      const mt = 1 - t;
      pts.push({
        x: mt * mt * x1 + 2 * mt * t * cx + t * t * x2,
        y: mt * mt * y1 + 2 * mt * t * cy + t * t * y2,
      });
    }
    return pts;
  }

  // Rounded "circuit trace" connector: straight down, rounded corner into a
  // horizontal run, then a rounded corner back to straight down — mirrors the
  // rounded-corner cards instead of a sharp diagonal cut. Returns both the
  // `d` fragment (for the visible path) and sampled points (for the LUT).
  function roundedConnector(x1, y1, x2, y2) {
    if (Math.abs(x2 - x1) < 1) {
      return { d: ` L ${x2} ${y2}`, points: linePoints(x1, y1, x2, y2) };
    }

    const dir  = x2 > x1 ? 1 : -1;
    const midY = (y1 + y2) / 2;
    const r1   = Math.min(CORNER_RADIUS, Math.abs(midY - y1));
    const r2   = Math.min(CORNER_RADIUS, Math.abs(y2 - midY));

    const b = { x: x1, y: midY - r1 };
    const c = { x: x1 + dir * r1, y: midY };
    const e = { x: x2 - dir * r2, y: midY };
    const f = { x: x2, y: midY + r2 };
    const g = { x: x2, y: y2 };

    const d =
      ` L ${b.x} ${b.y}` +
      ` Q ${x1} ${midY}, ${c.x} ${c.y}` +
      ` L ${e.x} ${e.y}` +
      ` Q ${x2} ${midY}, ${f.x} ${f.y}` +
      ` L ${g.x} ${g.y}`;

    const points = [
      ...linePoints(x1, y1, b.x, b.y),
      ...quadPoints(b.x, b.y, x1, midY, c.x, c.y),
      ...linePoints(c.x, c.y, e.x, e.y),
      ...quadPoints(e.x, e.y, x2, midY, f.x, f.y),
      ...linePoints(f.x, f.y, g.x, g.y),
    ];

    return { d, points };
  }

  function buildScrollPath() {
    if (!trackContainer || !trackPath || !servicesList || !aboutSection) return;

    const containerRect = trackContainer.getBoundingClientRect();
    const W = containerRect.width;
    const H = containerRect.height;
    if (!W || !H) return;

    const centerX = W / 2;
    const INSET = 24;

    const cards = Array.from(servicesList.querySelectorAll('.service-focus-card'));
    let d = `M ${centerX} 0`;
    let curX = centerX;
    let curY = 0;
    const points = [{ x: centerX, y: 0 }];

    const addConnector = (x2, y2) => {
      const seg = roundedConnector(curX, curY, x2, y2);
      d += seg.d;
      points.push(...seg.points);
      curX = x2; curY = y2;
    };

    cards.forEach((card) => {
      // Cards are scaled in/out of focus (scale-75 <-> scale-100, animated
      // over 1s) by the Cinematic Focus observer, so getBoundingClientRect()
      // returns a box whose size depends on which animation frame we sample —
      // anchoring bends to that would make them swim during the transition.
      // transform: scale() keeps the element's center fixed (default
      // transform-origin: center), so the rect's center is scale-independent;
      // combine it with offsetWidth/offsetHeight (the untransformed layout
      // box) to get a stable "at rest, in focus" box for the bend anchors.
      const r = card.getBoundingClientRect();
      const cx = (r.left + r.right) / 2;
      const cy = (r.top + r.bottom) / 2;
      const natW = card.offsetWidth;
      const natH = card.offsetHeight;
      const top    = cy - natH / 2 - containerRect.top;
      const bottom = cy + natH / 2 - containerRect.top;
      const left   = cx - natW / 2 - containerRect.left + INSET;
      const right  = cx + natW / 2 - containerRect.left - INSET;

      // bend in to touch the left edge of the card
      addConnector(left, top);

      // sweep across to the right edge of the same card
      addConnector(right, bottom);
    });

    // bend back to center for the "Who Are We" section — fixed offset from
    // the section's top (not a fraction of its height) so shortening the
    // section via padding doesn't drag this bend point along with it.
    const aboutRect = aboutSection.getBoundingClientRect();
    const aboutY = aboutRect.top - containerRect.top + 230;
    addConnector(centerX, aboutY);

    laserGlowTargets.forEach((g) => {
      const r = g.el.getBoundingClientRect();
      g.top = r.top - containerRect.top;
      g.left = r.left - containerRect.left;
      g.bottom = r.bottom - containerRect.top;
      if (g.patch) {
        // Half-width, 1.3x height — centered on the heading's own box.
        const patchWidth  = r.width / 2;
        const patchHeight = r.height * 1.3;
        g.patch.style.left   = `${g.left + (r.width - patchWidth) / 2}px`;
        g.patch.style.top    = `${g.top - (patchHeight - r.height) / 2}px`;
        g.patch.style.width  = `${patchWidth}px`;
        g.patch.style.height = `${patchHeight}px`;

        // Size the glow ellipse so its gradient reaches `transparent` right
        // at the patch's own edge (70% of the gradient's radius == half the
        // patch's width/height) — `.laser-glow-layer`'s clip then never cuts
        // across a still-visible part of the glow.
        g.spotW = patchWidth / 0.7;
        g.spotH = patchHeight / 0.7;
        g.spot.style.width  = `${g.spotW}px`;
        g.spot.style.height = `${g.spotH}px`;
      }
    });

    const clampX = (x) => Math.min(Math.max(x, 8), W - 8);

    // "Why Choose Us": stay straight through "Who Are We", then bend left to
    // run alongside the sticky heading for the section, then bend back to
    // center to connect into "Our Process".
    if (whySection && whyHeading) {
      const whyRect     = whySection.getBoundingClientRect();
      const whyHeadRect = whyHeading.getBoundingClientRect();
      // Shift the bend at the #about/#why-choose-us boundary up slightly so
      // the track's horizontal run sits inside #about rather than right on
      // the seam between the two sections' backgrounds.
      const whyTop      = whyRect.top - containerRect.top - window.innerHeight * 0.01;
      const whyBottom   = whyRect.bottom - containerRect.top;
      const whyLeftX    = clampX(whyHeadRect.left - containerRect.left - INSET);

      addConnector(centerX, Math.max(curY, whyTop - BEND_HEIGHT));
      addConnector(whyLeftX, Math.max(curY, whyTop + BEND_HEIGHT));
      addConnector(whyLeftX, Math.max(curY, whyBottom - BEND_HEIGHT));
      addConnector(centerX, Math.max(curY, whyBottom + BEND_HEIGHT));
    }

    // "FAQ": stay straight through "Our Process", then repeat the same left
    // excursion alongside the FAQ heading, then return to center to finish.
    if (faqSection && faqHeading) {
      const faqRect     = faqSection.getBoundingClientRect();
      const faqHeadRect = faqHeading.getBoundingClientRect();
      // Same nudge as the #why-choose-us bend above: keep the horizontal run
      // inside #testimonials rather than on the seam with #faq.
      const faqTop      = faqRect.top - containerRect.top - window.innerHeight * 0.01;
      const faqBottom   = faqRect.bottom - containerRect.top;
      const faqLeftX    = clampX(faqHeadRect.left - containerRect.left - INSET);

      addConnector(centerX, Math.max(curY, faqTop - BEND_HEIGHT));
      addConnector(faqLeftX, Math.max(curY, faqTop + BEND_HEIGHT));
      addConnector(faqLeftX, Math.max(curY, faqBottom - BEND_HEIGHT));
      addConnector(centerX, Math.max(curY, faqBottom + BEND_HEIGHT));
    }

    // straight run for the rest of the page
    d += ` L ${centerX} ${H}`;
    points.push(...linePoints(curX, curY, centerX, H));

    trackPath.setAttribute('d', d);
    if (trackSvg) trackSvg.setAttribute('viewBox', `0 0 ${W} ${H}`);

    // Rebuild the lookup table used by computeTargetLen()/renderLaserAt().
    let cumLen = 0;
    pathSamples = [{ len: 0, x: points[0].x, y: points[0].y }];
    for (let i = 1; i < points.length; i++) {
      const prev = points[i - 1];
      const cur = points[i];
      cumLen += Math.hypot(cur.x - prev.x, cur.y - prev.y);
      pathSamples.push({ len: cumLen, x: cur.x, y: cur.y });
    }

    // Y has flat plateaus along each bend's horizontal run (every sample in
    // that run shares the same Y), which makes len(Y) a step function — a
    // tiny scroll across the plateau's Y used to snap `len` across the whole
    // run. Spread each plateau's samples over a small Y band (`ys`) so len(Y)
    // becomes continuous everywhere: steep through bends, ~1:1 elsewhere.
    // The position-easing loop then turns that steep stretch into a smooth
    // glide instead of chasing a teleport.
    const n = pathSamples.length;
    let i = 0;
    while (i < n) {
      let j = i;
      while (j + 1 < n && pathSamples[j + 1].y === pathSamples[i].y) j++;
      const Yp = pathSamples[i].y;
      if (j > i) {
        let eps = 24;
        if (i > 0) eps = Math.min(eps, (Yp - pathSamples[i - 1].y) / 2 - 0.01);
        if (j < n - 1) eps = Math.min(eps, (pathSamples[j + 1].y - Yp) / 2 - 0.01);
        eps = Math.max(eps, 0.01);
        const count = j - i + 1;
        for (let k = 0; k < count; k++) {
          pathSamples[i + k].ys = Yp - eps + (2 * eps) * (k / (count - 1));
        }
      } else {
        pathSamples[i].ys = Yp;
      }
      i = j + 1;
    }
  }

  // Where along the track the laser *should* be, based on scroll position.
  // Binary-search the precomputed table (by the smoothed `ys`) for the sample
  // matching the target scroll position — pure array math, no SVG geometry
  // queries on the hot path. renderLaserAt() is driven by an eased value that
  // chases this target, smoothing out the steep stretches around bends into a
  // gentle glide.
  function computeTargetLen() {
    if (pathSamples.length < 2) return 0;
    const startY = pathSamples[0].ys;
    const endY = pathSamples[pathSamples.length - 1].ys;
    const targetY = Math.min(Math.max(window.scrollY + window.innerHeight * 0.4, startY), endY);

    let lo = 0, hi = pathSamples.length - 1;
    while (lo < hi) {
      const mid = (lo + hi) >> 1;
      if (pathSamples[mid].ys < targetY) lo = mid + 1; else hi = mid;
    }
    return pathSamples[lo].len;
  }

  function renderLaserAt(L) {
    if (!laserLayers.length || pathSamples.length < 2) return;

    const totalLength = pathSamples[pathSamples.length - 1].len;
    const segStart = Math.max(0, L - LASER_LENGTH / 2);
    const segEnd   = Math.min(totalLength, L + LASER_LENGTH / 2);

    let i0 = 0, i1 = pathSamples.length - 1;
    while (i0 < i1) {
      const mid = (i0 + i1) >> 1;
      if (pathSamples[mid].len < segStart) i0 = mid + 1; else i1 = mid;
    }
    let j0 = 0, j1 = pathSamples.length - 1;
    while (j0 < j1) {
      const mid = (j0 + j1 + 1) >> 1;
      if (pathSamples[mid].len > segEnd) j1 = mid - 1; else j0 = mid;
    }

    let d = '';
    for (let i = i0; i <= j1; i++) {
      const p = pathSamples[i];
      d += i === i0 ? `M ${p.x} ${p.y}` : ` L ${p.x} ${p.y}`;
    }
    if (d) {
      for (const layer of laserLayers) layer.setAttribute('d', d);
    }
  }

  // Interpolated point on the track at arc-length L — used to position the
  // "illumination" glow on sections the laser passes behind.
  function getPointAtLen(L) {
    const n = pathSamples.length;
    if (n < 2) return { x: 0, y: 0 };
    let lo = 0, hi = n - 1;
    while (lo < hi) {
      const mid = (lo + hi) >> 1;
      if (pathSamples[mid].len < L) lo = mid + 1; else hi = mid;
    }
    if (lo === 0) return { x: pathSamples[0].x, y: pathSamples[0].y };
    const a = pathSamples[lo - 1], b = pathSamples[lo];
    const t = b.len > a.len ? (L - a.len) / (b.len - a.len) : 0;
    return { x: a.x + (b.x - a.x) * t, y: a.y + (b.y - a.y) * t };
  }

  // Fades each glow target in/out as the laser's current point enters and
  // leaves its vertical range, and keeps the glow centred under the laser
  // while it's inside.
  const LASER_GLOW_FADE = 200; // px ramp at a target's top/bottom edges
  function updateLaserGlows(point) {
    laserGlowTargets.forEach(({ spot, top, left, bottom, spotW, spotH, isTitle }) => {
      if (!spot) return;

      let intensity = 0;
      if (point.y < top) {
        intensity = 1 - (top - point.y) / LASER_GLOW_FADE;
      } else if (point.y > bottom) {
        intensity = 1 - (point.y - bottom) / LASER_GLOW_FADE;
      } else {
        intensity = 1;
      }
      intensity = Math.max(0, Math.min(1, intensity));

      spot.style.opacity = String(intensity * 0.8);
      // Title spots stay centred on the heading (see .laser-glow-spot--title)
      // so the glow never travels onto the track's bend above/below it.
      if (!isTitle && intensity > 0) {
        const relX = point.x - left;
        const relY = point.y - top;
        spot.style.transform = `translate(${relX - spotW / 2}px, ${relY - spotH / 2}px)`;
      }
    });
  }

  // Eased "current" position chases the scroll-driven target every frame —
  // decouples the laser from scroll-event frequency (smoother on trackpads)
  // and turns the bend-plateau jumps into quick smooth slides.
  // Two cascaded exponential filters (a fast one chasing the raw target, a
  // slower one chasing that) approximate a critically-damped spring: the
  // result eases in AND out, so a sudden change in scroll direction curves
  // smoothly instead of reversing velocity instantly — no "stuck then snap"
  // feeling. Rates are expressed per-1000ms so the glide feels the same
  // regardless of display refresh rate (60Hz vs 120/144Hz).
  const LASER_EASE_FAST_PER_SEC = 9;
  const LASER_EASE_SLOW_PER_SEC = 4.5;
  let midLen = 0;
  let currentLen = 0;
  let targetLen = 0;
  let lastFrameTime = 0;

  function refreshScrollTrack() {
    buildScrollPath();
    currentLen = midLen = targetLen = computeTargetLen();
    renderLaserAt(currentLen);
    updateLaserGlows(getPointAtLen(currentLen));
  }

  function laserLoop(now) {
    if (!lastFrameTime) lastFrameTime = now;
    const dt = (now - lastFrameTime) / 1000;
    lastFrameTime = now;

    targetLen = computeTargetLen();
    const fastFactor = 1 - Math.exp(-LASER_EASE_FAST_PER_SEC * dt);
    const slowFactor = 1 - Math.exp(-LASER_EASE_SLOW_PER_SEC * dt);
    midLen += (targetLen - midLen) * fastFactor;
    currentLen += (midLen - currentLen) * slowFactor;

    if (Math.abs(targetLen - currentLen) < 0.05 && Math.abs(midLen - currentLen) < 0.05) {
      midLen = currentLen = targetLen;
    }
    renderLaserAt(currentLen);
    updateLaserGlows(getPointAtLen(currentLen));
    requestAnimationFrame(laserLoop);
  }

  let trackResizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(trackResizeTimer);
    trackResizeTimer = setTimeout(refreshScrollTrack, 150);
  });

  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(refreshScrollTrack);
  }
  window.addEventListener('load', refreshScrollTrack);
  refreshScrollTrack();
  requestAnimationFrame(laserLoop);

  // Scroll Animations Logic
  let scrollTicking = false;
  window.addEventListener('scroll', () => {
    if (scrollTicking) return;
    scrollTicking = true;

    requestAnimationFrame(() => {
      // 1. Horizontal Scroll (Projects Section)
      const projectsContainer = document.getElementById('projects-scroll-container');
      const projectsTrack = document.getElementById('projects-track');

      if (projectsContainer && projectsTrack) {
        const rect = projectsContainer.getBoundingClientRect();
        if (rect.top <= 0 && rect.bottom >= window.innerHeight) {
          const scrollProgress = Math.abs(rect.top) / (rect.height - window.innerHeight);
          const maxScroll = projectsTrack.scrollWidth - window.innerWidth;
          projectsTrack.style.transform = `translateX(-${scrollProgress * maxScroll}px)`;
        } else if (rect.top > 0) {
          projectsTrack.style.transform = `translateX(0px)`;
        } else if (rect.bottom < window.innerHeight) {
          const maxScroll = projectsTrack.scrollWidth - window.innerWidth;
          projectsTrack.style.transform = `translateX(-${maxScroll}px)`;
        }
      }

      scrollTicking = false;
    });
  });

  // 2. Scroll Spy (Why Choose Us)
  const whyItems = document.querySelectorAll('.why-item');
  if (whyItems.length > 0) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-30', 'blur-sm', 'scale-95');
          entry.target.classList.add('opacity-100', 'blur-0', 'scale-100');
        } else {
          entry.target.classList.add('opacity-30', 'blur-sm', 'scale-95');
          entry.target.classList.remove('opacity-100', 'blur-0', 'scale-100');
        }
      });
    }, { rootMargin: '-25% 0px -55% 0px' });

    whyItems.forEach(item => observer.observe(item));
  }

  // 3. Cinematic Focus (Services)
  const serviceCards = document.querySelectorAll('.service-focus-card');
  if (serviceCards.length > 0) {
    const focusObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-20', 'scale-75', 'blur-lg', 'bg-surface-900/10');
          entry.target.classList.add('opacity-100', 'scale-100', 'blur-0', 'bg-surface-900/85', 'shadow-[0_0_40px_rgba(33,165,237,0.15)]', 'border-brand-500/30');
        } else {
          entry.target.classList.add('opacity-20', 'scale-75', 'blur-lg', 'bg-surface-900/10');
          entry.target.classList.remove('opacity-100', 'scale-100', 'blur-0', 'bg-surface-900/85', 'shadow-[0_0_40px_rgba(33,165,237,0.15)]', 'border-brand-500/30');
        }
      });
    }, { rootMargin: '-35% 0px -35% 0px' });

    serviceCards.forEach(card => focusObserver.observe(card));
  }
</script>



