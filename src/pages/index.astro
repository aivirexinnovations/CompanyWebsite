>
  <Navbar />

  <main id="main-content" class="relative">

    <!-- Global Scroll-Tracking Laser Background -->
    <div id="scroll-track-container" class="absolute inset-0 pointer-events-none -z-50 overflow-hidden" aria-hidden="true">
      <!-- The bending track line + the laser that travels along it -->
      <svg id="scroll-track-svg" class="absolute top-0 left-0 w-full h-full" preserveAspectRatio="none">
        <defs>
          <linearGradient id="track-gradient" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%"   stop-color="#21a5ed" stop-opacity="0" />
            <stop offset="12%"  stop-color="#21a5ed" stop-opacity="0.35" />
            <stop offset="88%"  stop-color="#21a5ed" stop-opacity="0.35" />
            <stop offset="100%" stop-color="#21a5ed" stop-opacity="0" />
          </linearGradient>
        </defs>

        <!-- Ambient track -->
        <path id="scroll-track-path" d="" fill="none" stroke="url(#track-gradient)" stroke-width="1.5" />

        <!-- Laser glow: stacked translucent strokes fake a soft blur without an
             SVG filter — feGaussianBlur is expensive to rasterize on weak/old
             devices, especially recomputed every frame. Widest+faintest first,
             brightest+narrowest last. -->
        <path id="scroll-laser-glow-3" d="" fill="none" stroke="#21a5ed" stroke-width="22" stroke-linecap="round" stroke-opacity="0.05" />
        <path id="scroll-laser-glow-2" d="" fill="none" stroke="#21a5ed" stroke-width="14" stroke-linecap="round" stroke-opacity="0.09" />
        <path id="scroll-laser-glow-1" d="" fill="none" stroke="#21a5ed" stroke-width="8"  stroke-linecap="round" stroke-opacity="0.18" />
        <path id="scroll-laser-halo"   d="" fill="none" stroke="#5fc7ff" stroke-width="5"  stroke-linecap="round" stroke-opacity="0.35" />
        <path id="scroll-laser-core"   d="" fill="none" stroke="#5fc7ff" stroke-width="2.5" stroke-linecap="round" />
      </svg>
    </div>

    <!-- Floating "illumination" patches for title-only laser-glow targets.
         Sits above the track (-z-50) but below section-local decoratives
         (-z-10, e.g. dot-grid backgrounds), so it can occlude the track
         behind a heading without covering that decoration. -->
    <div id="laser-glow-patches" class="absolute inset-0 pointer-events-none -z-[15] overflow-hidden" aria-hidden="true"></div>

    <!-- ═══════════════════════════════════════════
         1 · CLARITY HERO — lens of clarity
         Aurora base + flow-field currents that clarify and spiral toward the
         cursor, hidden customer-nodes that light up when found, a decode
         headline (chaos→clarity), and a prism chromatic lens rim.
    ═══════════════════════════════════════════ -->
    <section
      id="hero"
      class="relative min-h-screen flex flex-col overflow-hidden bg-[#03060f]"
      aria-label="Hero"
    >
      <HeroClarityCanvas />
      <!-- Left legibility wash -->
      <div class="absolute inset-0 bg-gradient-to-r from-[#03060f] via-[#03060f]/70 to-transparent pointer-events-none" aria-hidden="true"></div>
      <!-- Film grain -->
      <div class="absolute inset-0 bg-grain opacity-40 mix-blend-overlay pointer-events-none" aria-hidden="true"></div>
      <!-- Bottom fade into next section -->
      <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-surface-base to-transparent pointer-events-none" aria-hidden="true"></div>

      <!-- Clarity content (matches /herotrials concept 21) -->
      <div class="flex-1 flex items-center w-full">
        <div class="max-w-7xl mx-auto px-6 sm:px-10 w-full relative z-10 pt-28" data-reveal="blur">
          <div class="max-w-2xl">
            <span class="inline-flex items-center gap-2 mb-7 text-xs font-medium tracking-[0.18em] uppercase text-brand-300">
              <span class="w-6 h-px bg-brand-400"></span> Clarity from chaos
            </span>

            <Badge text="⭐ Rated 4.8/5 on Google" color="brand" class="mb-5" />

            <!-- Decode headline (resolves on load; data-final uses | for the line break) -->
            <h1 data-scramble data-final="Get found|by AI." class="font-display font-800 text-white leading-[0.98] tracking-[-0.03em] text-[clamp(2.7rem,6.4vw,5.4rem)] min-h-[1.95em]">
              Get found<br />by AI.
            </h1>

            <p class="mt-7 max-w-lg text-lg sm:text-xl text-slate-300/85 leading-relaxed">
              We research it, build it, and make sure both Google and AI assistants put you in front of buyers, websites, automations, software, or a product from scratch. You focus on the business. We handle the rest.
            </p>

            <div class="mt-10 flex flex-wrap gap-4">
              <a href="https://calendar.google.com/calendar/appointments/schedules/AcZssZ3sYUI78UrX97keSKdPPhEMyDVTvqApJos040zUwJcm3c_WquNTxBZFlb8m7ltooiunzs_DFHr8?gv=true" target="_blank" rel="noopener noreferrer" class="px-7 py-3.5 rounded-full bg-brand-500 hover:bg-brand-400 text-white font-semibold transition-colors shadow-[0_0_40px_-6px_rgba(33,165,237,0.6)]">Book a call</a>
              <a href="#projects" class="px-7 py-3.5 rounded-full border border-white/15 hover:border-white/35 text-white font-semibold transition-colors">See our work</a>
            </div>

            <p data-clarity-hint class="mt-8 text-xs tracking-[0.2em] uppercase text-white/35">move your cursor — bring them into focus</p>
          </div>
        </div>
      </div>

      <!-- Floating glass stats dashboard, pinned to the bottom of the hero -->
      <div class="relative z-10 max-w-7xl mx-auto px-6 sm:px-10 w-full">
        <div id="hero-dashboard" class="relative w-full max-w-5xl mx-auto [perspective:1400px] group">
          <div class="w-full h-[200px] sm:h-[260px] bg-surface-900/40 backdrop-blur-3xl border-t border-x border-white/10 rounded-t-[3rem] shadow-[0_-20px_100px_rgba(0,0,0,0.5)] transform sm:rotate-x-12 sm:translate-y-12 sm:group-hover:rotate-x-0 sm:group-hover:translate-y-0 transition-transform duration-1000 ease-out-expo overflow-hidden flex items-end justify-center pb-10 sm:pb-14 relative">

            <!-- Scanning light sweep along the top edge -->
            <div class="absolute top-0 inset-x-0 h-px overflow-hidden">
              <div class="absolute inset-y-0 w-1/3 bg-gradient-to-r from-transparent via-brand-400 to-transparent animate-scan-x"></div>
            </div>

            <!-- Fade to base color at bottom so it blends into the next section -->
            <div class="absolute inset-0 bg-gradient-to-t from-surface-base via-transparent to-transparent z-10 pointer-events-none"></div>

            <div class="relative z-20 grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-8 w-full px-8">
              {stats.map(s => (
                <div class="text-center group-hover:-translate-y-2 transition-transform duration-700 delay-100">
                  <div class="text-4xl sm:text-5xl lg:text-6xl font-display font-800 text-white mb-2" data-count-to={s.value}>0</div>
                  <div class="text-xs sm:text-sm font-medium tracking-wider text-slate-400">{s.label}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         2 · SERVICES (Cinematic Focus)
    ═══════════════════════════════════════════ -->
