---
// src/pages/projects/index.astro
// Full project portfolio — every project we've shipped, in depth.
import BaseLayout    from '../../layouts/BaseLayout.astro';
import Navbar        from '../../components/Navbar.astro';
import Footer        from '../../components/Footer.astro';
import Badge         from '../../components/ui/Badge.astro';
import Button        from '../../components/ui/Button.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';

import { projects } from '../../data/projects.js';
---

<BaseLayout
  title="Our Work | AiVirex Projects Portfolio"
  description="Every project AiVirex has shipped — websites, AI agents and automations, products, and custom software — with the real metrics behind each one."
  keywords="AiVirex projects, AiVirex portfolio, custom software case studies, AI automation case studies, web development portfolio"
  canonicalUrl="https://aivirex.in/projects"
>
  <Navbar />

  <main id="main-content" class="pt-16">

    <!-- Page Hero -->
    <div class="py-20 lg:py-28 text-center relative overflow-hidden">
      <div class="absolute inset-0 -z-10" aria-hidden="true">
        <div class="blob-brand absolute top-1/3 left-1/4 -translate-x-1/2 w-[800px] h-[500px] rounded-full blur-[100px] mix-blend-screen opacity-50 animate-pulse"></div>
        <div class="absolute inset-0 bg-grain opacity-50 mix-blend-overlay"></div>
      </div>
      <div class="max-w-3xl mx-auto px-4 sm:px-6" data-reveal="blur">
        <SectionHeader
          heading={`Our <span class="text-brand-500">Work</span>`}
          subheading="Every project we've shipped — websites, AI agents and automations, products, and custom software — with the real metrics behind each one."
        />
        <Button href="https://calendar.google.com/calendar/appointments/schedules/AcZssZ3sYUI78UrX97keSKdPPhEMyDVTvqApJos040zUwJcm3c_WquNTxBZFlb8m7ltooiunzs_DFHr8?gv=true" target="_blank" rel="noopener noreferrer" variant="primary">
          Book a Call
        </Button>
      </div>
    </div>

    <!-- Project List -->
    <section class="section pt-0" aria-label="All projects">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        {projects.map((p, i) => (
          <div id={p.slug} class="grid grid-cols-1 sm:grid-cols-[1.1fr_1fr] gap-8 lg:gap-16 items-center py-12 sm:py-16 border-t border-white/5 first:border-t-0" data-reveal="blur">

            <!-- Image -->
            <a href={p.href} target={p.href ? '_blank' : undefined} rel={p.href ? 'noopener noreferrer' : undefined} class:list={['block rounded-2xl overflow-hidden border border-white/10 bg-surface-800 aspect-[4/3] lg:aspect-video group', !p.href && 'pointer-events-none']}>
              <img src={p.image} alt={p.title} class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out-expo" loading="lazy" />
            </a>

            <!-- Content -->
            <div>
              <div class="flex items-center gap-3 mb-4">
                <span class="text-sm font-mono text-slate-500">{String(i + 1).padStart(2, '0')}</span>
                <Badge text={p.tag} />
              </div>

              <h2 class="text-2xl sm:text-3xl font-display font-700 text-white mb-3 leading-tight">{p.title}</h2>
              <p class="text-slate-400 leading-relaxed">{p.description}</p>

              <div class="flex flex-wrap gap-2 mt-4">
                {p.technologies.map(t => (
                  <span class="text-[11px] text-slate-400 bg-white/5 border border-white/10 rounded-full px-2.5 py-1">{t}</span>
                ))}
              </div>

              {p.href && (
                <a href={p.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-4 text-brand-400 hover:text-brand-300 font-semibold uppercase tracking-wider text-xs transition-colors duration-200">
                  View Live Site
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                </a>
              )}

              <div class="grid grid-cols-2 gap-3 mt-6">
                {p.metrics.map(m => (
                  <div class="border border-white/10 rounded-xl px-4 py-3 bg-surface-900/40">
                    <div class="text-lg sm:text-xl font-display font-800 text-brand-400">{m.value}</div>
                    <div class="text-xs text-slate-500 mt-1">{m.name}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
