---
// src/pages/projects/index.astro
// Full project portfolio — every project we've shipped, in depth.
import BaseLayout    from '../../layouts/BaseLayout.astro';
import Navbar        from '../../components/Navbar.astro';
import Footer        from '../../components/Footer.astro';
import Badge         from '../../components/ui/Badge.astro';
import Button        from '../../components/ui/Button.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';

import { projects, pageFaqs } from '../../data/projects.js';

// JSON-LD: Organization + one CreativeWork/SoftwareApplication per project + one
// FAQPage covering the page level FAQ and every project's faqs. Built from the
// same projects.js data the page renders, so it can't drift out of sync.
const orgId = 'https://aivirex.in/#org';
const softwareSlugs = new Set([
  'adtown', 'dispatchiq', 'attendify', 'hazlo', 'techiegen', 'temple-billing-system',
  'data-analysis-tool', 'colorcoding-tool', 'medicaldata', 'plant-species-classification',
  'loan-approval-system', 'stockmarket-automation',
]);

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': orgId,
  name: 'AiVirex Innovations LLP',
  url: 'https://aivirex.in',
  description: 'AiVirex builds zero to one products, AI agents and automations, AI visible websites, and custom software, with 20 plus products shipped across India and the USA.',
};

const projectSchemas = projects.map(p => ({
  '@context': 'https://schema.org',
  '@type': softwareSlugs.has(p.slug) ? 'SoftwareApplication' : 'CreativeWork',
  name: p.title,
  creator: { '@id': orgId },
  description: p.nugget || p.description,
  ...(p.href ? { url: p.href } : {}),
}));

const allFaqs = [...pageFaqs, ...projects.flatMap(p => p.faqs || [])];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allFaqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const schemas = [orgSchema, ...projectSchemas, faqSchema];
---

<BaseLayout
  title="Our Work | AiVirex Projects Portfolio"
  description="Every project AiVirex has shipped — websites, AI agents and automations, products, and custom software — with the real metrics behind each one."
  keywords="AiVirex projects, AiVirex portfolio, custom software case studies, AI automation case studies, web development portfolio"
  canonicalUrl="https://aivirex.in/projects"
  schemas={schemas}
>
  <Navbar />

  <main id="main-content" class="pt-16">

    <!-- Page Hero -->
    <div class="py-20 lg:py-28 text-center relative overflow-hidden">
      <div class="absolute inset-0 -z-10" aria-hidden="true">
        <div class="blob-brand absolute top-1/3 left-1/4 -translate-x-1/2 w-[800px] h-[500px] rounded-full blur-[100px] mix-blend-screen opacity-50 animate-pulse"></div>
        <div class="absolute inset-0 bg-grain opacity-50 mix-blend-overlay"></div>
      </div>
      <div class="max-w-3xl mx-auto px-4 sm:px-6" data-reveal="blur">
        <SectionHeader
          heading={`Our <span class="text-brand-500">Work</span>`}
          subheading="Every project we've shipped — websites, AI agents and automations, products, and custom software — with the real metrics behind each one."
        />
        <Button href="https://calendar.google.com/calendar/appointments/schedules/AcZssZ3sYUI78UrX97keSKdPPhEMyDVTvqApJos040zUwJcm3c_WquNTxBZFlb8m7ltooiunzs_DFHr8?gv=true" target="_blank" rel="noopener noreferrer" variant="primary">
          Book a Call
        </Button>
      </div>
    </div>

    <!-- Project List -->
    <section class="section pt-0" aria-label="All projects">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        {projects.map((p, i) => (
          <div id={p.slug} class="grid grid-cols-1 sm:grid-cols-[1.1fr_1fr] gap-8 lg:gap-16 items-center py-12 sm:py-16 border-t border-white/5 first:border-t-0" data-reveal="blur">

            <!-- Image -->
            <a href={p.href} target={p.href ? '_blank' : undefined} rel={p.href ? 'noopener noreferrer' : undefined} class:list={['block rounded-2xl overflow-hidden border border-white/10 bg-surface-800 aspect-[4/3] lg:aspect-video group', !p.href && 'pointer-events-none']}>
              <img src={p.image} alt={p.title} class="w-full h-full object-contain scale-125 transform group-hover:scale-[1.3] transition-transform duration-700 ease-out-expo" loading="lazy" />
            </a>

            <!-- Content -->
            <div>
              <div class="flex items-center gap-3 mb-4">
                <span class="text-sm font-mono text-slate-500">{String(i + 1).padStart(2, '0')}</span>
                <Badge text={p.tag} />
              </div>

              <h2 class="text-2xl sm:text-3xl font-display font-700 text-white mb-3 leading-tight">{p.title}</h2>

              {p.questionHeading && (
                <h3 class="text-base sm:text-lg font-display font-600 text-brand-300 mb-3 leading-snug">{p.questionHeading}</h3>
              )}

              {p.caseStudy && (
                <p class="text-slate-400 leading-relaxed">{p.caseStudy}</p>
              )}

              {p.nugget && (
                <p class="font-semibold text-white leading-relaxed mt-4 pl-4 border-l-2 border-brand-500/40">{p.nugget}</p>
              )}

              <p class="text-slate-400 leading-relaxed mt-4">{p.description}</p>

              <div class="flex flex-wrap gap-2 mt-4">
                {p.technologies.map(t => (
                  <span class="text-[11px] text-slate-400 bg-white/5 border border-white/10 rounded-full px-2.5 py-1">{t}</span>
                ))}
              </div>

              {p.href && (
                <a href={p.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-4 text-brand-400 hover:text-brand-300 font-semibold uppercase tracking-wider text-xs transition-colors duration-200">
                  View Live Site
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                </a>
              )}

              <div class="grid grid-cols-2 gap-3 mt-6">
                {p.metrics.map(m => (
                  <div class="border border-white/10 rounded-xl px-4 py-3 bg-surface-900/40">
                    <div class="text-lg sm:text-xl font-display font-800 text-brand-400">{m.value}</div>
                    <div class="text-xs text-slate-500 mt-1">{m.name}</div>
                  </div>
                ))}
              </div>

              {p.faqs && p.faqs.length > 0 && (
                <div class="mt-6 space-y-3">
                  {p.faqs.map(f => (
                    <details class="group border border-white/10 rounded-xl px-4 py-3 bg-surface-900/40">
                      <summary class="text-sm font-semibold text-white cursor-pointer list-none">{f.q}</summary>
                      <p class="text-sm text-slate-400 leading-relaxed mt-2">{f.a}</p>
                    </details>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Page level FAQ -->
    <section class="section pt-0" aria-label="Frequently asked questions">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <SectionHeader
          heading={`Frequently Asked <span class="text-brand-500">Questions</span>`}
        />
        <div class="space-y-3 mt-8">
          {pageFaqs.map(f => (
            <details class="group border border-white/10 rounded-xl px-5 py-4 bg-surface-900/40">
              <summary class="text-base font-semibold text-white cursor-pointer list-none">{f.q}</summary>
              <p class="text-sm text-slate-400 leading-relaxed mt-2">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
