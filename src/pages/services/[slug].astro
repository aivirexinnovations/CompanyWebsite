---
// src/pages/services/[slug].astro
// One template, four service pages, driven by src/data/services.js.
// Long, editorial style pages built from an ordered `sections` array. Single
// consistent left aligned column (max-w-5xl) for the whole story so nothing
// zigzags between left and centre. Reuses the homepage design system plus the
// global data-reveal scroll animations (heavy "blur" for headline moments,
// lighter "up" + stagger for dense card grids).
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar     from '../../components/Navbar.astro';
import Footer     from '../../components/Footer.astro';
import Badge      from '../../components/ui/Badge.astro';
import Button     from '../../components/ui/Button.astro';

import { services } from '../../data/services.js';

const BOOKING_URL = 'https://calendar.google.com/calendar/appointments/schedules/AcZssZ3sYUI78UrX97keSKdPPhEMyDVTvqApJos040zUwJcm3c_WquNTxBZFlb8m7ltooiunzs_DFHr8?gv=true';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const canonical = `https://aivirex.in/services/${service.slug}`;

const areaServed = ['United States', 'United Kingdom', 'Canada', 'Australia', 'India']
  .map((name) => ({ '@type': 'Country', name }));

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.navLabel,
  serviceType: service.navLabel,
  description: service.directAnswer,
  url: canonical,
  provider: { '@type': 'Organization', name: 'AiVirex Innovations LLP', url: 'https://aivirex.in' },
  areaServed,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: service.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://aivirex.in' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://aivirex.in/services' },
    { '@type': 'ListItem', position: 3, name: service.navLabel, item: canonical },
  ],
};

const schemas = [serviceSchema, faqSchema, breadcrumbSchema];
const stagger = (i) => `stagger-${(i % 6) + 1}`;
---

<BaseLayout
  title={service.metaTitle}
  description={service.metaDescription}
  keywords={service.keywords}
  canonicalUrl={canonical}
  includeHreflang={true}
  schemas={schemas}
>
  <Navbar />

  <main id="main-content" class="pt-16">

    <!-- Hero -->
    <section class="pt-14 pb-16 lg:pt-20 lg:pb-24 text-center relative overflow-hidden" aria-labelledby="service-hero-heading">
      <div class="absolute inset-0 -z-10" aria-hidden="true">
        <div class="blob-brand absolute top-1/4 left-1/2 -translate-x-1/2 w-[760px] h-[460px] rounded-full blur-[110px] mix-blend-screen opacity-50 animate-pulse"></div>
        <div class="absolute inset-0 bg-dots opacity-[0.4]"></div>
      </div>

      <!-- Breadcrumb / loop back home -->
      <nav class="max-w-3xl mx-auto px-4 sm:px-6 mb-7 flex items-center justify-center gap-2 text-xs sm:text-sm text-slate-500" aria-label="Breadcrumb">
        <a href="/" class="inline-flex items-center gap-1.5 hover:text-brand-300 transition-colors font-medium">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.5 1.5 0 012.12 0L22.5 12M4.5 9.75v10.125a1.125 1.125 0 001.125 1.125H9.75v-4.875a1.125 1.125 0 011.125-1.125h2.25a1.125 1.125 0 011.125 1.125V21h4.125a1.125 1.125 0 001.125-1.125V9.75"/></svg>
          Home
        </a>
        <span class="text-slate-600" aria-hidden="true">/</span>
        <a href="/services" class="hover:text-brand-300 transition-colors font-medium">Services</a>
        <span class="text-slate-600" aria-hidden="true">/</span>
        <span class="text-slate-300">{service.navLabel}</span>
      </nav>

      <div class="max-w-3xl mx-auto px-4 sm:px-6" data-sr>
        <div class="flex justify-center mb-6">
          <Badge text={service.eyebrow} dot />
        </div>
        <h1
          id="service-hero-heading"
          class="text-4xl sm:text-5xl lg:text-6xl font-display font-700 text-white leading-tight"
          set:html={service.h1}
        />
        <p class="text-slate-300/85 mt-6 text-lg leading-relaxed max-w-2xl mx-auto">{service.heroSub}</p>
        <div class="mt-9 flex flex-wrap gap-4 justify-center">
          <Button href={BOOKING_URL} target="_blank" rel="noopener noreferrer" variant="primary" size="lg">
            Book a call
          </Button>
          <Button href="/projects" variant="secondary" size="lg" arrow={false}>
            See our work
          </Button>
        </div>
      </div>
    </section>

    <!-- Editorial column: one consistent left edge for the whole story -->
    <div class="max-w-5xl mx-auto px-5 sm:px-6 lg:px-8">

      <!-- Lead (direct answer, quotable GEO/AEO surface) -->
      <div class="border-l-2 border-brand-500/60 pl-5 sm:pl-7 py-1" data-sr="left">
        <p class="text-xl sm:text-2xl text-slate-100 font-display font-400 leading-relaxed">{service.directAnswer}</p>
      </div>

      <!-- Story arc -->
      {service.sections.map((block) => {
        const header = (
          <header class="mb-9 max-w-3xl" data-sr="left">
            {block.eyebrow && (
              <p class="eyebrow mb-3 flex items-center gap-3">
                <span class="inline-block w-8 h-px bg-brand-500" aria-hidden="true"></span>
                {block.eyebrow}
              </p>
            )}
            <h2 class="text-3xl sm:text-[2.5rem] font-display font-700 text-white leading-[1.12]">{block.heading}</h2>
            {block.intro && <p class="text-slate-400 mt-4 leading-relaxed text-lg">{block.intro}</p>}
          </header>
        );

        if (block.type === 'prose') {
          return (
            <section class="py-12 lg:py-16">
              {header}
              <div class="space-y-5 max-w-3xl" data-sr>
                {block.paragraphs.map((p, i) => (
                  <p class={`text-slate-300/90 leading-relaxed ${i === 0 ? 'text-lg sm:text-xl' : 'text-lg'}`}>{p}</p>
                ))}
              </div>
            </section>
          );
        }

        if (block.type === 'problems') {
          return (
            <section class="py-12 lg:py-16">
              {header}
              <div class="grid md:grid-cols-2 gap-4">
                {block.items.map((item, i) => (
                  <div class={`flex items-start gap-4 glass rounded-2xl p-5 sm:p-6 ${stagger(i)}`} data-sr="zoom">
                    <span class="flex items-center justify-center w-9 h-9 rounded-xl bg-white/5 border border-white/10 text-slate-300 font-mono font-bold text-sm flex-shrink-0">{String(i + 1).padStart(2, '0')}</span>
                    <div>
                      <h3 class="text-base sm:text-lg font-display font-700 text-white mb-1 leading-snug">{item.title}</h3>
                      <p class="text-sm text-slate-400 leading-relaxed">{item.body}</p>
                    </div>
                  </div>
                ))}
              </div>
            </section>
          );
        }

        if (block.type === 'stats') {
          return (
            <section class="py-12 lg:py-16">
              {header}
              <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
                {block.items.map((stat, i) => (
                  <div class={`glass-strong rounded-2xl p-6 border-t-2 border-brand-500/40 ${stagger(i)}`} data-sr="zoom">
                    <div class="text-3xl sm:text-4xl lg:text-[2.75rem] font-display font-800 text-brand-400 leading-none">{stat.value}</div>
                    <div class="text-xs sm:text-sm text-slate-400 mt-3 leading-snug">{stat.label}</div>
                  </div>
                ))}
              </div>
            </section>
          );
        }

        if (block.type === 'callout') {
          return (
            <section class="py-8 lg:py-12">
              <div class="glass-brand rounded-3xl px-7 py-9 sm:px-11 sm:py-11 relative overflow-hidden" data-sr>
                <div class="blob-brand absolute -top-1/2 -right-10 w-[400px] h-[300px] rounded-full blur-[80px] opacity-40" aria-hidden="true"></div>
                <svg class="w-9 h-9 text-brand-500/40 mb-4 relative" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
                <p class="text-xl sm:text-2xl lg:text-[1.7rem] font-display font-600 text-white leading-snug relative">{block.text}</p>
              </div>
            </section>
          );
        }

        if (block.type === 'steps') {
          return (
            <section class="py-12 lg:py-16">
              {header}
              <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
                {block.steps.map((step, i) => (
                  <div class={`relative glass rounded-2xl p-6 pt-7 overflow-hidden ${stagger(i)}`} data-sr>
                    <span class="absolute -top-3 -right-1 text-7xl font-display font-800 text-white/[0.04] select-none leading-none" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                    <div class="relative">
                      <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-brand-500/15 border border-brand-500/30 text-brand-300 text-sm font-bold font-mono mb-4">{i + 1}</span>
                      <h3 class="text-base font-display font-700 text-white mb-2 leading-snug">{step.title}</h3>
                      <p class="text-sm text-slate-400 leading-relaxed">{step.body}</p>
                    </div>
                  </div>
                ))}
              </div>
            </section>
          );
        }

        if (block.type === 'features') {
          return (
            <section class="py-12 lg:py-16">
              {header}
              <div class="grid md:grid-cols-2 gap-4">
                {block.items.map((item, i) => (
                  <div class={`group flex items-start gap-4 glass rounded-2xl p-5 sm:p-6 card-hover ${stagger(i)}`} data-sr>
                    <span class="flex items-center justify-center w-10 h-10 rounded-xl bg-brand-500/12 border border-brand-500/25 text-brand-300 flex-shrink-0 group-hover:bg-brand-500/20 transition-colors">
                      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                    </span>
                    <div>
                      <h3 class="text-base sm:text-lg font-display font-700 text-white mb-1.5 leading-snug">{item.title}</h3>
                      <p class="text-sm text-slate-400 leading-relaxed">{item.body}</p>
                    </div>
                  </div>
                ))}
              </div>
            </section>
          );
        }

        return null;
      })}

      <div class="divider-x my-4" aria-hidden="true"></div>

      <!-- Proof redirect (no repeated project cards, just a door to the work) -->
      <section class="py-12 lg:py-16" aria-label="Proof">
        <div class="glass rounded-3xl px-6 py-9 sm:px-11 sm:py-11 flex flex-col sm:flex-row items-center justify-between gap-6" data-sr>
          <div>
            <h2 class="text-2xl sm:text-3xl font-display font-700 text-white leading-tight">Want to see the results?</h2>
            <p class="text-slate-400 mt-2 max-w-md">Real projects, real numbers. The full story of what we've shipped lives on the work page.</p>
          </div>
          <Button href="/projects" variant="secondary" size="lg" class="flex-shrink-0">
            See our work
          </Button>
        </div>
      </section>

      <!-- FAQ -->
      <section class="py-12 lg:py-16" aria-labelledby="faq-heading">
        <header class="mb-9 max-w-3xl" data-sr>
          <p class="eyebrow mb-3 flex items-center gap-3">
            <span class="inline-block w-8 h-px bg-brand-500" aria-hidden="true"></span>
            FAQ
          </p>
          <h2 id="faq-heading" class="text-3xl sm:text-[2.5rem] font-display font-700 text-white leading-[1.12]">Questions, <span class="text-brand-500">answered</span></h2>
        </header>
        <div class="space-y-3 max-w-3xl">
          {service.faqs.map((f, i) => (
            <details class={`group glass rounded-xl px-5 py-4 ${stagger(i)}`} data-sr>
              <summary class="text-base font-semibold text-white cursor-pointer list-none flex items-center justify-between gap-4">
                {f.q}
                <svg class="w-5 h-5 text-brand-400 flex-shrink-0 transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
              </summary>
              <p class="text-sm text-slate-400 leading-relaxed mt-3">{f.a}</p>
            </details>
          ))}
        </div>
      </section>
    </div>

    <!-- Closing CTA -->
    <section class="pt-6 pb-20 lg:pb-28" aria-label="Get started">
      <div class="max-w-4xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="glass-brand rounded-3xl px-6 py-12 sm:px-12 sm:py-14 text-center relative overflow-hidden" data-sr>
          <div class="blob-brand absolute -top-1/2 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full blur-[90px] opacity-40" aria-hidden="true"></div>
          <h2 class="text-3xl sm:text-4xl font-display font-700 text-white leading-tight relative">Not sure exactly what you need?</h2>
          <p class="text-slate-300 mt-4 max-w-xl mx-auto relative">That's the call. Tell us where you're stuck and we'll tell you what's actually possible, then scope it and give you a clear, tailored quote.</p>
          <div class="mt-8 flex flex-wrap gap-4 justify-center relative">
            <Button href={BOOKING_URL} target="_blank" rel="noopener noreferrer" variant="primary" size="lg">
              Book a free strategy call
            </Button>
            <Button href="/" variant="secondary" size="lg" arrow={false}>
              Back to home
            </Button>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
